# =========================
# 📦 SCENARIO RUNNER (SAFE)
# =========================

run_scenario_file() {
  local file="$1"

  if [ ! -f "$file" ]; then
    echo "[!] Scenario tidak ditemukan: $file"
    return 1
  fi

  echo "[~] Running scenario: $(basename "$file")"

  local line=0

  while IFS= read -r cmd || [ -n "$cmd" ]; do
    ((line++))

    # skip kosong
    [ -z "$cmd" ] && continue

    # skip comment
    [[ "$cmd" =~ ^# ]] && continue

    # trim
    cmd=$(echo "$cmd" | xargs)

    [ -z "$cmd" ] && continue

    echo "[SCENARIO:$line] $cmd"

    run_command "$cmd"

    # STOP kalau recovery aktif
    if [ "$RECOVERY_MODE" -eq 1 ]; then
      echo "[!] Recovery aktif → stop scenario"
      break
    fi

  done

  echo "[✔] Scenario selesai"
  return 0
}

# =========================
# ⚙️ BACKGROUND INSTALL (SAFE)
# =========================

background_install() {
  for pkg in nmap dialog figlet; do
    if ! command -v "$pkg" >/dev/null 2>&1; then
      echo "[~] Installing $pkg (background)..."

      (
        sudo apt update -y >/dev/null 2>&1
        sudo apt install -y "$pkg" >/dev/null 2>&1
      ) &
    fi
  done
}

