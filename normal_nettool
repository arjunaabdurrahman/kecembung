      	echo -e "${CYAN}=========================${NC}"

      	IFS= read -r -p "Pilih menu: " sub || continue

      	case $sub in
          1)
  	    shopt -s nullglob
            files=("$SCENARIO_DIR"/*.sh)
            shopt -u nullglob

  	    if [ ${#files[@]} -eq 0 ]; then
              echo "[!] Tidak ada scenario"
              continue
            fi
          
      	      echo -e "${CYAN}=========================${NC}"
    	      echo -e "${CYAN}   DAFTAR SCENARIO${NC}"
    	      echo -e "${CYAN}=========================${NC}"

    	      for i in "${!files[@]}"; do
      	        echo "$i. $(basename "${files[$i]}")"
    	      done

    	      echo -e "${CYAN}=========================${NC}"

    	      read -p "Pilih scenario: " pilih

   	      if [ -n "${files[$pilih]}" ]; then
      	        echo "[~] Menjalankan scenario..."

     	        while IFS= read -r cmd || [ -n "$cmd" ]; do

		  [ -z "$cmd" ] && continue

  		  [[ "$cmd" =~ ^# ]] && continue
  		  
  		  cmd=$(echo "$cmd" | xargs)
                  [ -z "$cmd" ] && continue

	          case "$cmd" in

        	    cmd_lihat_ip) cmd_lihat_ip ;;
	            cmd_scan_jaringan) cmd_scan_jaringan ;;
	            cmd_ping_ip) cmd_ping_ip ;;
         	    cmd_set_ip_manual) cmd_set_ip_manual ;;
	            cmd_routing) cmd_routing ;;
	            cmd_dns_check) cmd_dns_check ;;
	            cmd_internet_check) cmd_internet_check ;;
       	            cmd_scan_ssh) cmd_scan_ssh ;;
                    cmd_ssh_connect) cmd_ssh_connect ;;
	            cmd_reset_ip) cmd_reset_ip ;;

	            cmd_tcp_scan_port) cmd_tcp_scan_port ;;
	            cmd_tcp_service_detection) cmd_tcp_service_detection ;;
	            cmd_tcp_range_scan) cmd_tcp_range_scan ;;
	            cmd_tcp_specific_port) cmd_tcp_specific_port ;;
	            cmd_tcp_local_ports) cmd_tcp_local_ports ;;
	            cmd_tcp_banner_grab) cmd_tcp_banner_grab ;;

	            cmd_ai_webcam_all) cmd_ai_webcam_all ;;
	            cmd_ai_webcam_person) cmd_ai_webcam_person ;;
	            cmd_ai_rtsp) cmd_ai_rtsp ;;
	            cmd_ai_image) cmd_ai_image ;;
	            cmd_ai_video) cmd_ai_video ;;
	            cmd_ai_train) cmd_ai_train ;;
	            cmd_ai_run) cmd_ai_run ;;

	            cmd_storage_local) cmd_storage_local ;;
	            cmd_storage_usb) cmd_storage_usb ;;
	            cmd_storage_install) cmd_storage_install ;;
 	            cmd_storage_save_log) cmd_storage_save_log ;;

	            cmd_usb_detect) cmd_usb_detect ;;
	            cmd_usb_select) cmd_usb_select ;;
	            cmd_usb_workspace) cmd_usb_workspace ;;
	            cmd_usb_read) cmd_usb_read ;;
	            cmd_usb_delete) cmd_usb_delete ;;

	            *)
	              echo "[!] Unknown command: $cmd"
	              ;;
	          esac

	        done < "${files[$pilih]}"

	        echo "[✔] Selesai"
	        log_save "Run Scenario $(basename "${files[$pilih]}")"

	      else
	        echo "[!] Pilihan tidak valid"
	      fi
	  ;;

          2)
            if [ -f ~/scenario_builder.sh ]; then
    	      bash ~/scenario_builder.sh
            else
    	      echo "[!] scenario_builder.sh tidak ditemukan"
            fi
	    ;;

          3)
             break
             ;;
        esac

      done
      ;;
             
    # =====================
    # 🚪 EXIT
    # =====================
    6)
      echo -e "${RED}Exiting NETTOOLS...${NC}"

      pkill -P $$ 2>/dev/null
      kill "$WATCHDOG_PID" 2>/dev/null

      sleep 1
      clear
      break
      ;;

    *)
      echo -e "${RED}Invalid option${NC}"
      ;;

    esac


done

