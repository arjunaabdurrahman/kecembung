trap_ctrlc() {

  if [ "$RECOVERY_MODE" -eq 1 ]; then
    return
  fi

  echo ""
  echo "[!] CTRL+C DETECTED → RETURN TO MAIN MENU"

  INTERRUPTED=1
  RECOVERY_MODE=1
  RETURN_TO_MAIN=1

  kill_process "$CURRENT_CHILD"
  kill_process "$CURRENT_PID"

  CURRENT_CHILD=""
  CURRENT_PID=0

  validate_child
}

trap trap_ctrlc SIGINT

reset_state() {
  INTERRUPTED=0
  RETURN_TO_MAIN=0
  RECOVERY_MODE=0
  CRASH_FLAG=0

  if [ -n "$CURRENT_CHILD" ]; then
    kill_process "$CURRENT_CHILD" 2>/dev/null
  fi

  CURRENT_CHILD=""
  CURRENT_PID=0
}

# =========================
# 🛡️ SELF-HEAL SAFE RUNNER
# =========================

safe_run() {
  write_heartbeat "AI_RUN"
  validate_child

  local timeout_sec="$1"
  shift
  local cmd=("$@")

  setsid "${cmd[@]}" &
  local pid=$!

  set_child "$pid"

  if [ -z "$CURRENT_CHILD" ]; then
    echo "[!] SAFE RUN: gagal spawn"
    return 1
  fi

  local status=0

  if [ "$timeout_sec" -gt 0 ]; then

    for ((i=0; i<timeout_sec; i++)); do

      if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
        wait "$CURRENT_CHILD" 2>/dev/null
        status=$?
        CURRENT_CHILD=""
        return $status
      fi

      sleep 1

      if [ "$RECOVERY_MODE" -eq 1 ]; then
        kill_process "$CURRENT_CHILD"
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""
        return 1
      fi
    done

    echo "[!] SAFE RUN: timeout (${timeout_sec}s)"

    kill_process "$CURRENT_CHILD"
    wait "$CURRENT_CHILD" 2>/dev/null
    CURRENT_CHILD=""

    return 124
  fi

  wait "$CURRENT_CHILD" 2>/dev/null
  status=$?

  validate_child
  CURRENT_CHILD=""

  return $status
}

