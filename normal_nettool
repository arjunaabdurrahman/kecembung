check_update() {

  echo "[~] Mengecek update..."

  # cek internet cepat
  ping -c 1 8.8.8.8 &>/dev/null || return

  LATEST_VERSION=$(curl -s --max-time 5 "$VERSION_URL")

  if [ -z "$LATEST_VERSION" ]; then
    echo "[!] Gagal ambil versi terbaru"
    return
  fi

  if [ "$LATEST_VERSION" != "$CURRENT_VERSION" ]; then

    echo ""
    echo "================================="
    echo "⚠️ UPDATE TERSEDIA!"
    echo "Versi kamu : $CURRENT_VERSION"
    echo "Versi baru : $LATEST_VERSION"
    echo ""

    echo "Perubahan:"
    curl -s "$CHANGELOG_URL"
    echo ""

    echo "1. Update sekarang"
    echo "2. Nanti"
    echo "================================="

    IFS= read -r -p "Pilih: " pilih

    case $pilih in
      1)
        do_update
        ;;
      2)
        echo "[~] Melewati update..."
        ;;
      *)
        echo "[!] Pilihan tidak valid"
        ;;
    esac

  fi
}

do_update() {

  echo ""
  echo "[~] Memulai update NETTOOLS..."
  sleep 1

  TMP_DIR="/tmp/nettool_update"
  mkdir -p "$TMP_DIR"

  SCRIPT_PATH="$(realpath "$0")"
  TMP_FILE="$TMP_DIR/nettool_new"

  echo "[~] Downloading update..."

  curl -fsSL --max-time 15 "$SCRIPT_URL" -o "$TMP_FILE"

  # VALIDASI download
  if [ ! -s "$TMP_FILE" ]; then
    echo "[!] Gagal download update (file kosong)"
    rm -rf "$TMP_DIR"
    return
  fi

  # VALIDASI basic (biar bukan file rusak)
  if ! head -n 1 "$TMP_FILE" | grep -q "#!/bin/bash"; then
    echo "[!] File update tidak valid!"
    rm -rf "$TMP_DIR"
    return
  fi

  chmod +x "$TMP_FILE"

  echo "[~] Backup script lama..."
  cp "$SCRIPT_PATH" "$SCRIPT_PATH.bak"

  if [ $? -ne 0 ]; then
    echo "[!] Gagal backup"
    rm -rf "$TMP_DIR"
    return
  fi

  echo "[~] Mengganti script..."

  mv "$TMP_FILE" "$SCRIPT_PATH"
  chmod +x "$SCRIPT_PATH"

  if [ $? -ne 0 ]; then
    echo "[!] Gagal replace script!"
    echo "[~] Restore backup..."
    cp "$SCRIPT_PATH.bak" "$SCRIPT_PATH"
    rm -rf "$TMP_DIR"
    return
  fi

  rm -rf "$TMP_DIR"

  echo "[✔] Update berhasil!"
  echo "[~] Restarting NETTOOLS..."
  sleep 1

  exec "$SCRIPT_PATH"
}

