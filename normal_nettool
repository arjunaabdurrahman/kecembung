#watchdog_loop() {
  local WATCHDOG_TIMEOUT=120
  local recovery_lock_file="/tmp/nettools_recovery.lock"

  while true; do
    sleep 2

    cleanup_child

    [ "$RECOVERY_MODE" -eq 1 ] && {
      write_heartbeat "RECOVERY"
      continue
    }

    [ ! -f "$WATCHDOG_FILE" ] && continue

    line=$(cat "$WATCHDOG_FILE" 2>/dev/null)

    last=$(echo "$line" | cut -d'|' -f1)
    src=$(echo "$line" | cut -d'|' -f2)

    # VALIDATION HARD
    [[ ! "$last" =~ ^[0-9]+$ ]] && continue

    now=$(date +%s)
    diff=$((now - last))

    # IGNORE SHORT SPIKES
    if [ "$diff" -lt 3 ]; then
      continue
    fi

    if [ "$diff" -ge "$WATCHDOG_TIMEOUT" ]; then

      # GLOBAL LOCK (ANTI DOUBLE RECOVERY)
      if [ -f "$recovery_lock_file" ]; then
        continue
      fi

      touch "$recovery_lock_file"

      echo "[!] WATCHDOG: freeze detected (${diff}s from $src)"

      kill_process "$CURRENT_CHILD"
      kill_process "$CURRENT_PID"

      CURRENT_CHILD=""
      CURRENT_PID=0

      RETURN_TO_MAIN=1
      RECOVERY_MODE=1
      INTERRUPTED=1

      write_heartbeat "WATCHDOG_RECOVERY"

      log_save "WATCHDOG TRIGGERED ($src)"

      # unlock after short cooldown
      (
        sleep 5
        rm -f "$recovery_lock_file"
      ) &
    fi
  done
}

