safe_kill() {
  local pid="$1"

  if [ -z "$pid" ]; then
    return
  fi

  # mark dulu biar sistem lain stop intervensi
  PROCESS_MAIN=""
  PROCESS_CHILD=""

  kill "$pid" 2>/dev/null
  sleep 0.5

  kill -TERM "$pid" 2>/dev/null
  sleep 1

  kill -KILL "$pid" 2>/dev/null

  wait "$pid" 2>/dev/null
}

kill_process() {
  local pid="$1"

  if [ -z "$pid" ]; then
    return 0
  fi

  if ! kill -0 "$pid" 2>/dev/null; then
    return 0
  fi

  safe_kill "$pid"
}

register_child() {
  PROCESS_CHILD="$1"
}

# =========================
# 🧠 PID SAFETY LAYER 
# =========================

is_alive() {
  [ -n "$1" ] && kill -0 "$1" 2>/dev/null
}

cleanup_child() {
  if [ -n "$CURRENT_CHILD" ]; then
    if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
      echo "[CLEANUP] stale CURRENT_CHILD removed ($CURRENT_CHILD)"
      CURRENT_CHILD=""
    fi
  fi
}

validate_child() {
  if [ -n "$CURRENT_CHILD" ] && ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
    echo "[CLEANUP] stale CURRENT_CHILD removed ($CURRENT_CHILD)"
    CURRENT_CHILD=""
  fi
}

set_child() {
  local pid="$1"

  sleep 0.1

  if [ -z "$pid" ] || ! kill -0 "$pid" 2>/dev/null; then
    echo "[WARN] invalid CHILD PID"
    CURRENT_CHILD=""
    return 1
  fi

  CURRENT_CHILD="$pid"
  return 0
}

# =========================
# SAFE AI RUN 
# =========================

safe_ai() {
  local timeout="$1"
  shift

  setsid "$@" &
  local pid=$!

  set_child "$pid"

  if [ -z "$CURRENT_CHILD" ]; then
    echo "[!] SAFE AI: gagal spawn process"
    return 1
  fi

  local start_time=$(date +%s)

  while kill -0 "$CURRENT_CHILD" 2>/dev/null; do
    write_heartbeat "AI_RUN"
    sleep 2

    if [ "$timeout" -gt 0 ]; then
      now=$(date +%s)
      diff=$((now - start_time))

      if [ "$diff" -ge "$timeout" ]; then
        echo "[!] SAFE AI: TIMEOUT ($timeout detik)"

        kill_process "$CURRENT_CHILD"
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""

        return 124
      fi
    fi
  done

  wait "$CURRENT_CHILD" 2>/dev/null
  local status=$?

  validate_child
  CURRENT_CHILD=""

  return $status
}

