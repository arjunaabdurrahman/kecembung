}

cmd_usb_delete() {
  clear

  echo ""

  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] No USB selected"

    echo ""
    read -p "Tekan ENTER untuk kembali..."
    return
  fi

  echo "[!] Deleting: $USB_PATH/*"
  echo "[⚠] This action cannot be undone"
  echo ""

  read -p "Type YES to confirm: " confirm

  [ "$confirm" != "YES" ] && return

  if [[ "$USB_PATH" != /media/* && "$USB_PATH" != /run/media/* ]]; then
    echo "[!] BLOCKED: not a real USB mount"

    echo ""
    read -p "Tekan ENTER untuk kembali..."
    return
  fi

  if [ ! -d "$USB_PATH" ]; then
    echo "[!] Invalid path"

    echo ""
    read -p "Tekan ENTER untuk kembali..."
    return
  fi

  find "$USB_PATH" -mindepth 1 -maxdepth 5 -exec rm -rf {} \;
  sync

  echo "[✔] USB cleaned successfully"

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

