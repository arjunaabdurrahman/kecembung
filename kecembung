cmd_syn_flood_detect() {
  clear
  print_section "SYN FLOOD DETECTOR - ANTI DDOS"

  print_info "Menganalisa koneksi SYN_RECV..."
  echo ""

  syn_count=$(ss -ant 2>/dev/null | grep -c "SYN-RECV")
  syncookies=$(cat /proc/sys/net/ipv4/tcp_syncookies 2>/dev/null)

  echo -e "${CYAN}=============================${NC}"
  echo -e "${CYAN}  HASIL ANALISA${NC}"
  echo -e "${CYAN}=============================${NC}"
  echo ""

  print_keyval "SYN_RECV total" "$syn_count koneksi"

  if [ "$syncookies" = "1" ]; then
    print_keyval "SYN Cookies" "$(echo -e "${GREEN}AKTIF${NC} (terlindungi)")"
  else
    print_keyval "SYN Cookies" "$(echo -e "${RED}TIDAK AKTIF${NC} (rentan!)")"
  fi

  echo ""

  if [ "$syn_count" -gt 100 ]; then
    echo -e "${RED}[⚠] PERINGATAN: SYN FLOOD TERDETEKSI!${NC}"
    echo -e "${RED}    $syn_count koneksi SYN_RECV aktif${NC}"
    echo ""
    echo "Top IP penyerang:"
    echo ""
    ss -ant 2>/dev/null | grep "SYN-RECV" | awk '{print $5}' | \
      cut -d: -f1 | sort | uniq -c | sort -rn | head -10 | \
      while read -r count ip; do
        printf "  ${RED}%-20s${NC} %s attempts\n" "$ip" "$count"
      done
    echo "[$(date '+%F %T')] SYN FLOOD: $syn_count SYN_RECV" >> "$LOG_DIR/syn_flood.log"
  elif [ "$syn_count" -gt 50 ]; then
    echo -e "${YELLOW}[!] WASPADA: $syn_count SYN_RECV (mulai tinggi)${NC}"
  else
    print_success "Kondisi normal ($syn_count SYN_RECV)"
  fi

  echo ""

  if [ "$syncookies" != "1" ]; then
    echo -e "${YELLOW}Aktifkan SYN Cookies untuk perlindungan? (Y/n): ${NC}"
    read -r ans
    ans="${ans:-Y}"
    if [ "$ans" = "Y" ] || [ "$ans" = "y" ]; then
      sudo sysctl -w net.ipv4.tcp_syncookies=1 >/dev/null
      echo "net.ipv4.tcp_syncookies=1" | sudo tee -a /etc/sysctl.conf >/dev/null
      print_success "SYN Cookies diaktifkan"
    fi
  fi

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

