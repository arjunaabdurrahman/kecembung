cmd_log_integrity_check() {
  clear
  print_section "LOG INTEGRITY CHECK - DETEKSI TAMPERING"

  HASH_FILE="$LOG_DIR/log_hashes.txt"
  LOG_TARGETS="/var/log/auth.log /var/log/syslog /var/log/kern.log /var/log/dpkg.log"

  echo "1. Simpan hash log sekarang (baseline)"
  echo "2. Cek integritas log"
  echo "3. Lihat history check"
  echo "4. Kembali"
  echo ""

  read -p "Pilih: " opt

  case $opt in
    1)
      echo ""
      print_info "Menyimpan hash baseline..."
      echo ""
      > "$HASH_FILE.new"
      for log in $LOG_TARGETS; do
        if [ -f "$log" ]; then
          hash=$(sha256sum "$log" | awk '{print $1}')
          echo "$log:$hash:$(date +%s)" >> "$HASH_FILE.new"
          print_success "$(basename "$log") → $hash"
        else
          print_error "$log tidak ditemukan"
        fi
      done
      mv "$HASH_FILE.new" "$HASH_FILE"
      print_success "Baseline disimpan"
      ;;

    2)
      echo ""
      if [ ! -f "$HASH_FILE" ]; then
        print_error "Belum ada baseline. Jalankan opsi 1 dulu."
        echo ""
        read -p "Tekan ENTER untuk kembali..."
        return
      fi

      print_info "Mengecek integritas log..."
      echo ""

      printf "%-30s %s\n" "FILE" "STATUS"
      echo "--------------------------------------------"

      while IFS=: read -r logfile stored_hash timestamp; do
        if [ ! -f "$logfile" ]; then
          printf "%-30s " "$(basename "$logfile")"
          echo -e "${RED}[FILE HILANG!]${NC}"
          echo "[$(date '+%F %T')] MISSING: $logfile" >> "$LOG_DIR/integrity.log"
          continue
        fi

        current_hash=$(sha256sum "$logfile" | awk '{print $1}')

        printf "%-30s " "$(basename "$logfile")"

        if [ "$current_hash" = "$stored_hash" ]; then
          echo -e "${GREEN}[✔ CLEAN]${NC}"
        else
          echo -e "${RED}[⚠ TAMPERED!]${NC}"
          echo "[$(date '+%F %T')] TAMPERED: $logfile" >> "$LOG_DIR/integrity.log"
        fi

      done < "$HASH_FILE"
      ;;

    3)
      echo ""
      if [ -f "$LOG_DIR/integrity.log" ]; then
        cat "$LOG_DIR/integrity.log"
      else
        print_info "Belum ada history check"
      fi
      ;;

    4) return ;;
  esac

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

