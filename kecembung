cmd_port_knock_setup() {
  clear
  print_section "PORT KNOCKING - SEMBUNYIKAN PORT SSH"

  echo "1. Install & setup knockd"
  echo "2. Lihat konfigurasi aktif"
  echo "3. Test knock sequence"
  echo "4. Kembali"
  echo ""

  read -p "Pilih: " opt

  case $opt in
    1)
      if ! command -v knockd >/dev/null 2>&1; then
        print_info "Menginstall knockd..."
        sudo apt install -y knockd >/dev/null 2>&1
      fi

      iface=$(ip route | grep default | awk '{print $5}' | head -1)

      read -p "Port sequence (contoh: 7000,8000,9000): " sequence
      sequence="${sequence:-7000,8000,9000}"

      read -p "Port yang mau dibuka (default: 22): " target_port
      target_port="${target_port:-22}"

      read -p "Timeout detik (default: 10): " timeout
      timeout="${timeout:-10}"

      sudo tee /etc/knockd.conf > /dev/null <<EOF
[options]
    Interface = $iface
    UseSyslog

[openSSH]
    sequence    = $sequence
    seq_timeout = $timeout
    command     = /sbin/iptables -A INPUT -s %IP% -p tcp --dport $target_port -j ACCEPT
    tcpflags    = syn

[closeSSH]
    sequence    = $(echo $sequence | tr ',' '\n' | tac | tr '\n' ',' | sed 's/,$//')
    seq_timeout = $timeout
    command     = /sbin/iptables -D INPUT -s %IP% -p tcp --dport $target_port -j ACCEPT
    tcpflags    = syn
EOF

      sudo systemctl enable knockd >/dev/null 2>&1
      sudo systemctl restart knockd

      echo ""
      print_success "Port knocking aktif !"
      echo ""
      echo -e "${CYAN}Sequence untuk buka port $target_port:${NC}"
      echo -e "${GREEN}  knock <server_ip> $sequence${NC}"
      echo ""
      echo -e "${CYAN}Sequence untuk tutup port $target_port:${NC}"
      reverse=$(echo $sequence | tr ',' '\n' | tac | tr '\n' ',' | sed 's/,$//')
      echo -e "${GREEN}  knock <server_ip> $reverse${NC}"
      ;;

    2)
