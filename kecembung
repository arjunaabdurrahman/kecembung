init_storage() {

  if [ -z "$storage_mode" ]; then
    storage_mode="local"
  fi

  if [ "$storage_mode" = "local" ]; then
    storage_path="$LOG_DIR"
  else
    if [ -z "$USB_PATH" ]; then
      storage_mode="local"
      storage_path="$LOG_DIR"
    else
      storage_path="$USB_PATH/KECEMBUNG"
    fi
  fi

  if [ -z "$storage_path" ] || [ "$storage_path" = "/" ]; then
    storage_path="$HOME/kecembung_logs"
  fi

  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"
}

log_save() {
  init_storage

  if [ ! -w "$storage_path" ]; then
    echo "[!] Storage not writable"
    return 1
  fi

  echo "[$(date '+%F %T')] $1" >> "$LOG_DIR/kecembung_log.txt" 2>/dev/null

  if [ $? -ne 0 ]; then
    echo "[!] Failed to write log"
  fi
}

# =========================
