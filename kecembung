init_storage() {

  if [ -z "$storage_mode" ]; then
    storage_mode="local"
  fi

  if [ "$storage_mode" = "local" ]; then
    storage_path="$LOG_DIR"
  else
    if [ -z "$USB_PATH" ]; then
      storage_mode="local"
      storage_path="$LOG_DIR"
    else
      storage_path="$USB_PATH/KECEMBUNG"
    fi
  fi

  if [ -z "$storage_path" ] || [ "$storage_path" = "/" ]; then
    storage_path="$HOME/kecembung_logs"
  fi

  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"
}

log_save() {
  init_storage

  if [ ! -w "$storage_path" ]; then
    echo "[!] Storage not writable"
    return 1
  fi

  echo "[$(date '+%F %T')] $1" >> "$LOG_DIR/kecembung_log.txt" 2>/dev/null

  if [ $? -ne 0 ]; then
    echo "[!] Failed to write log"
  fi
}

# =========================
# COMMAND MAP - IP TOOLS
# =========================

cmd_lihat_ip() {
  clear
  print_section "NETWORK INTERFACE STATUS"

  ip -brief address | while read -r line; do
    iface=$(echo "$line" | awk '{print $1}')
    state=$(echo "$line" | awk '{print $2}')
    ipaddr=$(echo "$line" | awk '{print $3}')

    print_keyval "Interface" "$iface"
    print_keyval "Status" "$state"
    print_keyval "IP" "${ipaddr:-NONE}"
    echo ""
  done

  read -p "Tekan ENTER untuk kembali..."
}

cmd_scan_jaringan() {
  init_storage

  if ! command -v nmap >/dev/null 2>&1; then
    print_error "nmap belum terinstall"
    return
  fi

  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24

  clear

  print_section "NETWORK SCAN"
  print_keyval "Subnet" "$net"
  echo ""

  print_info "Scanning network... tunggu sebentar"
  echo ""

  nmap -sn "$net" | awk '
    /Nmap scan report/ {print "\n- " $NF}
    /MAC Address/ {print "  MAC: " $0}
  '

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

cmd_ping_ip() {
  init_storage

  read -p "Target IP: " target

  if [ -z "$target" ]; then
    print_error "Target kosong"
    return
  fi

  print_section "PING TEST"
  print_keyval "Target" "$target"
  echo ""

  result=$(ping -c 4 "$target")

  loss=$(echo "$result" | grep -oP '\d+(?=% packet loss)')
  avg=$(echo "$result" | grep -oP 'rtt .* = .*\/\K[0-9.]+')

  if [[ "$loss" == "0" ]]; then
    print_success "HOST ONLINE"
  else
    print_error "PACKET LOSS: $loss%"
  fi

  print_keyval "Avg Latency" "${avg:-unknown} ms"

  read -p "Tekan ENTER untuk kembali..."
}

cmd_set_ip_manual() {
  if ! command -v nmcli >/dev/null 2>&1; then
    print_error "nmcli tidak tersedia di sistem ini"
    return
  fi

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eno|eth" | head -n 1 | cut -d: -f1)

  read -p "IP (contoh 192.168.1.10/24): " ipbaru
  read -p "Gateway: " gateway

  nmcli con mod "$koneksi" ipv4.addresses "$ipbaru"
  nmcli con mod "$koneksi" ipv4.gateway "$gateway"
  nmcli con mod "$koneksi" ipv4.method manual
  nmcli con up "$koneksi"

  print_section "IP CONFIGURATION"
  print_success "IP berhasil diubah"
  print_keyval "Interface" "$koneksi"
  print_keyval "IP Baru" "$ipbaru"
  print_keyval "Gateway" "$gateway"

  read -p "Tekan ENTER untuk kembali..."
}

cmd_routing() {
  print_section "ROUTING INFORMATION"

  gateway=$(ip route | grep default | awk '{print $3}')
  iface=$(ip route | grep default | awk '{print $5}')

  print_keyval "Default Gateway" "$gateway"
  print_keyval "Active Interface" "$iface"

  echo ""
  echo "ROUTES:"

  ip route | grep -v default | while read -r line; do
    echo "- $line"
  done

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

