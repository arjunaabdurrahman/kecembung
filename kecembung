  print_section "ARP WATCH - DETEKSI ARP SPOOFING"

  print_info "Memantau ARP table... CTRL+C untuk berhenti"
  echo ""

  declare -A arp_table

  while true; do
    clear
    print_section "ARP WATCH - LIVE MONITOR"
    echo ""

    while IFS= read -r line; do
      ip=$(echo "$line" | grep -oP '(\d+\.){3}\d+')
      mac=$(echo "$line" | grep -oP '([0-9a-f]{2}:){5}[0-9a-f]{2}')

      [ -z "$ip" ] || [ -z "$mac" ] && continue

      if [ -n "${arp_table[$ip]}" ] && [ "${arp_table[$ip]}" != "$mac" ]; then
        echo -e "${RED}[⚠] ANOMALI DETECTED!${NC}"
        echo -e "${RED}    IP    : $ip${NC}"
        echo -e "${RED}    MAC lama : ${arp_table[$ip]}${NC}"
        echo -e "${RED}    MAC baru : $mac${NC}"
        echo "[$(date '+%F %T')] ANOMALI: $ip MAC berubah ${arp_table[$ip]} -> $mac" >> "$LOG_DIR/arp_watch.log"
      else
        echo -e "${GREEN}[✔]${NC} $ip  →  $mac"
      fi

      arp_table[$ip]="$mac"

    done < <(ip neigh show 2>/dev/null)

    echo ""
    print_info "Refresh tiap 3 detik... CTRL+C untuk berhenti"
    sleep 3
  done
