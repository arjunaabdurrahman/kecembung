cmd_conn_monitor() {
  clear
  print_section "CONNECTION MONITOR - LIVE TRAFFIC"

  print_info "Memantau koneksi aktif... CTRL+C untuk berhenti"
  echo ""

  SUSPICIOUS_PORTS="4444 1337 31337 6666 6667 9999 8888"

  while true; do
    clear
    print_section "ACTIVE CONNECTIONS"
    echo ""

    printf "%-10s %-25s %-25s %-15s %s\n" "PROTO" "LOCAL" "REMOTE" "STATUS" "PROGRAM"
    echo "------------------------------------------------------------------------------------"

    ss -tupn 2>/dev/null | tail -n +2 | while read -r line; do
      proto=$(echo "$line" | awk '{print $1}')
      local=$(echo "$line" | awk '{print $5}')
      remote=$(echo "$line" | awk '{print $6}')
      status=$(echo "$line" | awk '{print $2}')
      prog=$(echo "$line" | awk '{print $NF}' | grep -oP 'users:\(\("\K[^"]+')

      remote_port=$(echo "$remote" | grep -oP ':\K\d+$')

      suspicious=0
      for sp in $SUSPICIOUS_PORTS; do
        [ "$remote_port" = "$sp" ] && suspicious=1
      done

      if [ "$suspicious" -eq 1 ]; then
        echo -e "${RED}[⚠]${NC} $(printf "%-10s %-25s %-25s %-15s %s" "$proto" "$local" "$remote" "$status" "${prog:-unknown}")"
        echo "[$(date '+%F %T')] SUSPICIOUS: $proto $local -> $remote $prog" >> "$LOG_DIR/conn_monitor.log"
      else
        printf "%-10s %-25s %-25s %-15s %s\n" "$proto" "$local" "$remote" "$status" "${prog:-unknown}"
      fi
    done

    echo ""
    print_info "Refresh tiap 2 detik... CTRL+C untuk berhenti"
    sleep 2
  done
}

