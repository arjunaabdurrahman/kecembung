# =========================
# 🔁 PROCESS TRACKING
# =========================

trap_ctrlc() {

  if [ "$RECOVERY_MODE" -eq 1 ]; then
    return
  fi

  echo ""
  echo "[!] CTRL+C DETECTED → RETURN TO MAIN MENU"

  INTERRUPTED=1
  RECOVERY_MODE=1
  RETURN_TO_MAIN=1

  kill_process "$CURRENT_CHILD"
  kill_process "$CURRENT_PID"

  CURRENT_CHILD=""
  CURRENT_PID=0

  validate_child
}

trap trap_ctrlc SIGINT

reset_state() {
  INTERRUPTED=0
  RETURN_TO_MAIN=0
  RECOVERY_MODE=0
  CRASH_FLAG=0

  if [ -n "$CURRENT_CHILD" ]; then
    kill_process "$CURRENT_CHILD" 2>/dev/null
  fi

  CURRENT_CHILD=""
  CURRENT_PID=0
}

# =========================
# 🛡️ SELF-HEAL SAFE RUNNER
# =========================

safe_run() {
  write_heartbeat "AI_RUN"
  validate_child

  local timeout_sec="$1"
  shift
  local cmd=("$@")

  setsid "${cmd[@]}" &
  local pid=$!

  set_child "$pid"

  if [ -z "$CURRENT_CHILD" ]; then
    echo "[!] SAFE RUN: gagal spawn"
    return 1
  fi

  local status=0

  if [ "$timeout_sec" -gt 0 ]; then

    for ((i=0; i<timeout_sec; i++)); do

      if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
        wait "$CURRENT_CHILD" 2>/dev/null
        status=$?
        CURRENT_CHILD=""
        return $status
      fi

      sleep 1

      if [ "$RECOVERY_MODE" -eq 1 ]; then
        kill_process "$CURRENT_CHILD"
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""
        return 1
      fi
    done

    echo "[!] SAFE RUN: timeout (${timeout_sec}s)"

    kill_process "$CURRENT_CHILD"
    wait "$CURRENT_CHILD" 2>/dev/null
    CURRENT_CHILD=""

    return 124
  fi

  wait "$CURRENT_CHILD" 2>/dev/null
  status=$?

  validate_child
  CURRENT_CHILD=""

  return $status
}

# =========================
# 🛡️ UPDATE CHECK
# =========================

check_update() {

  echo "[~] Mengecek update..."

  ping -c 1 8.8.8.8 &>/dev/null || {
    echo "[!] Tidak ada koneksi internet"
    return
  }

  HTTP_STATUS=$(curl -o /dev/null -s -w "%{http_code}" --max-time 5 "$VERSION_URL")

  if [ "$HTTP_STATUS" != "200" ]; then
    echo "[!] VERSION_URL tidak valid (HTTP $HTTP_STATUS)"
    return
  fi

  LATEST_VERSION=$(curl -s --max-time 5 "$VERSION_URL")

  if [ -z "$LATEST_VERSION" ]; then
    echo "[!] Gagal ambil versi terbaru (kosong)"
    return
  fi

  LATEST_VERSION=$(echo "$LATEST_VERSION" | tr -d ' \n\r')

  if [ "$LATEST_VERSION" != "$CURRENT_VERSION" ]; then

    echo ""
    echo "================================="
    echo "⚠️ UPDATE TERSEDIA!"
    echo "Versi kamu : $CURRENT_VERSION"
    echo "Versi baru : $LATEST_VERSION"
    echo ""

    echo "Perubahan:"
    curl -s --max-time 5 "$CHANGELOG_URL"
    echo ""

    echo "1. Update sekarang"
    echo "2. Nanti"
    echo "================================="

    IFS= read -r -p "Pilih: " pilih

    case "$pilih" in
      1) do_update ;;
      2) echo "[~] Melewati update..." ;;
      *) echo "[!] Pilihan tidak valid" ;;
    esac

  else
    echo "[✔] Sudah versi terbaru"
  fi
}

do_update() {

  UPDATE_SCRIPT="$HOME/.kecembung/update.sh"

  mkdir -p "$HOME/.kecembung"

  echo ""
  echo "[~] Preparing update engine..."

  curl -fsSL "$UPDATE_URL" -o "$UPDATE_SCRIPT"

  if [ ! -s "$UPDATE_SCRIPT" ]; then
    echo "[!] Gagal download update.sh"
    return 1
  fi

  chmod +x "$UPDATE_SCRIPT"

  clear

  echo "[~] Launching KECEMBUNG updater..."
  sleep 1

  bash "$UPDATE_SCRIPT"

  local status=$?

  if [ $status -ne 0 ]; then
    echo "[!] Update gagal"
    return 1
  fi

  echo ""
  echo "[✔] Update selesai"
  echo "[~] Restarting KECEMBUNG..."
  sleep 2

  exec "$0"
}

