cmd_scan_ssh() {
  if ! command -v nmap >/dev/null 2>&1; then
    print_error "nmap belum terinstall"
    return
  fi

  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24

  print_section "SSH SCAN"
  print_keyval "Subnet" "$net"
  echo ""

  echo "[~] Searching SSH devices (port 22)..."
  echo ""

  nmap -p 22 --open "$net" | awk '
    /Nmap scan report/ {print "- " $NF}
  '

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

cmd_ssh_connect() {
  read -p "Target IP: " target
  read -p "User: " user

  print_section "SSH CONNECTION"

  if [ -z "$target" ] || [ -z "$user" ]; then
    print_error "Input tidak lengkap"
    return
  fi

  print_keyval "Target" "$target"
  print_keyval "User" "$user"
  echo ""

  ssh "$user@$target"

  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

cmd_reset_ip() {
  if ! command -v nmcli >/dev/null 2>&1; then
    print_error "nmcli tidak tersedia"
    return
  fi

  print_section "NETWORK RESET"

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eth|eno" | head -n 1 | cut -d: -f1)

  if [ -z "$koneksi" ]; then
    print_error "Tidak ada koneksi aktif"
    return
  fi

  print_keyval "Interface" "$koneksi"
  echo ""

  echo "[~] Switching to DHCP mode..."

  sudo nmcli con mod "$koneksi" ipv4.method auto
  sudo nmcli con mod "$koneksi" ipv4.addresses ""
  sudo nmcli con mod "$koneksi" ipv4.gateway ""
  sudo nmcli con mod "$koneksi" ipv4.dns ""

