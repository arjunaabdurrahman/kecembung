      read -p "Tekan ENTER untuk kembali..."
      return
    fi
  fi

  echo "Path yang mau dimonitor:"
  echo "1. /etc (sistem config)"
  echo "2. /var/www (web server)"
  echo "3. /home (user files)"
  echo "4. Custom path"
  echo ""

  read -p "Pilih: " pathopt

  case $pathopt in
    1) watch_path="/etc" ;;
    2) watch_path="/var/www" ;;
    3) watch_path="/home" ;;
    4)
      read -p "Path: " watch_path
      if [ ! -d "$watch_path" ] && [ ! -f "$watch_path" ]; then
        print_error "Path tidak ditemukan"
        echo ""
        read -p "Tekan ENTER untuk kembali..."
        return
      fi
      ;;
    *) watch_path="/etc" ;;
  esac

  echo ""
  print_info "Memantau: $watch_path"
  print_info "CTRL+C untuk berhenti"
  echo ""
  printf "%-20s %-12s %s\n" "WAKTU" "EVENT" "FILE"
  echo "------------------------------------------------------------"

  inotifywait -m -r "$watch_path" \
    -e create -e modify -e delete -e moved_to -e moved_from \
    --format '%T %e %w%f' \
    --timefmt '%H:%M:%S' 2>/dev/null | while read -r time event file; do

    case $event in
      CREATE|MOVED_TO)
        color="$YELLOW"
        ;;
      DELETE|MOVED_FROM)
        color="$RED"
        ;;
      MODIFY)
        color="$CYAN"
        ;;
      *)
        color="$NC"
        ;;
    esac

    printf "%-20s " "$time"
    echo -ne "${color}"
    printf "%-12s " "$event"
    echo -e "${NC}$file"

    echo "[$(date '+%F %T')] $event: $file" >> "$LOG_DIR/file_monitor.log"

  done
}

