# =========================
# 🔁 PROCESS TRACKING
# =========================

trap_ctrlc() {

  if [ "$RECOVERY_MODE" -eq 1 ]; then
    return
  fi

  echo ""
  echo "[!] CTRL+C DETECTED → RETURN TO MAIN MENU"

  INTERRUPTED=1
  RECOVERY_MODE=1
  RETURN_TO_MAIN=1

  kill_process "$CURRENT_CHILD"
  kill_process "$CURRENT_PID"

  CURRENT_CHILD=""
  CURRENT_PID=0

  validate_child
}

trap trap_ctrlc SIGINT

reset_state() {
  INTERRUPTED=0
  RETURN_TO_MAIN=0
  RECOVERY_MODE=0
  CRASH_FLAG=0

  if [ -n "$CURRENT_CHILD" ]; then
    kill_process "$CURRENT_CHILD" 2>/dev/null
  fi

  CURRENT_CHILD=""
  CURRENT_PID=0
}

# =========================
# 🛡️ SELF-HEAL SAFE RUNNER
# =========================

safe_run() {
  write_heartbeat "AI_RUN"
  validate_child

  local timeout_sec="$1"
  shift
  local cmd=("$@")

  setsid "${cmd[@]}" &
  local pid=$!

  set_child "$pid"

  if [ -z "$CURRENT_CHILD" ]; then
    echo "[!] SAFE RUN: gagal spawn"
    return 1
  fi

  local status=0

  if [ "$timeout_sec" -gt 0 ]; then

    for ((i=0; i<timeout_sec; i++)); do

      if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
        wait "$CURRENT_CHILD" 2>/dev/null
        status=$?
        CURRENT_CHILD=""
        return $status
      fi

      sleep 1

      if [ "$RECOVERY_MODE" -eq 1 ]; then
        kill_process "$CURRENT_CHILD"
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""
        return 1
      fi
    done

    echo "[!] SAFE RUN: timeout (${timeout_sec}s)"

    kill_process "$CURRENT_CHILD"
    wait "$CURRENT_CHILD" 2>/dev/null
    CURRENT_CHILD=""

    return 124
  fi

  wait "$CURRENT_CHILD" 2>/dev/null
  status=$?

  validate_child
  CURRENT_CHILD=""

  return $status
}

# =========================
# 🛡️ UPDATE CHECK
# =========================

check_update() {

  echo "[~] Mengecek update..."

  ping -c 1 8.8.8.8 &>/dev/null || {
    echo "[!] Tidak ada koneksi internet"
    return
  }

  HTTP_STATUS=$(curl -o /dev/null -s -w "%{http_code}" --max-time 5 "$VERSION_URL")

  if [ "$HTTP_STATUS" != "200" ]; then
    echo "[!] VERSION_URL tidak valid (HTTP $HTTP_STATUS)"
    return
  fi

  LATEST_VERSION=$(curl -s --max-time 5 "$VERSION_URL")

  if [ -z "$LATEST_VERSION" ]; then
    echo "[!] Gagal ambil versi terbaru (kosong)"
    return
  fi

  LATEST_VERSION=$(echo "$LATEST_VERSION" | tr -d ' \n\r')

  if [ "$LATEST_VERSION" != "$CURRENT_VERSION" ]; then

    echo ""
    echo "================================="
    echo "⚠️ UPDATE TERSEDIA!"
    echo "Versi kamu : $CURRENT_VERSION"
    echo "Versi baru : $LATEST_VERSION"
    echo ""

    echo "Perubahan:"
    curl -s --max-time 5 "$CHANGELOG_URL"
    echo ""

    echo "1. Update sekarang"
    echo "2. Nanti"
    echo "================================="

    IFS= read -r -p "Pilih: " pilih

    case "$pilih" in
      1) do_update ;;
      2) echo "[~] Melewati update..." ;;
      *) echo "[!] Pilihan tidak valid" ;;
    esac

  else
    echo "[✔] Sudah versi terbaru"
    clear
  fi
}

do_update() {
  UPDATE_SCRIPT="$HOME/.kecembung/update.sh"
  mkdir -p "$HOME/.kecembung"

  echo ""
  echo "[~] Preparing update engine..."
  curl -fsSL "$UPDATE_URL" -o "$UPDATE_SCRIPT"

  if [ ! -s "$UPDATE_SCRIPT" ]; then
    echo "[!] Gagal download update.sh"
    return 1
  fi

  chmod +x "$UPDATE_SCRIPT"
  clear
  echo "[~] Launching KECEMBUNG updater..."
  sleep 1

  bash "$UPDATE_SCRIPT"
  local status=$?

  if [ $status -ne 0 ]; then
    echo "[!] Update gagal"
    return 1
  fi

  # =========================
  # 🔍 CEK COMPONENT BARU
  # =========================
  MODE_FILE="$HOME/.kecembung_mode"
  [ ! -f "$MODE_FILE" ] && touch "$MODE_FILE"
  source "$MODE_FILE"

  AI_DETECT=${AI_DETECT:-0}
  AI_TRAIN=${AI_TRAIN:-0}
  AI_CHAT=${AI_CHAT:-0}
  SCENARIO=${SCENARIO:-0}
  OFFENSIVE=${OFFENSIVE:-0}

  # List component yang belum aktif
  NEW_ITEMS=()
  NEW_LABELS=()
  NEW_KEYS=()

  [ "$AI_DETECT" -eq 0 ] && NEW_ITEMS+=("AI Detect") && NEW_LABELS+=("Object detection via webcam, RTSP, image, video") && NEW_KEYS+=("1")
  [ "$AI_TRAIN"  -eq 0 ] && NEW_ITEMS+=("AI Train")  && NEW_LABELS+=("Train custom YOLO models") && NEW_KEYS+=("2")
  [ "$AI_CHAT"   -eq 0 ] && NEW_ITEMS+=("AI Chat")   && NEW_LABELS+=("Local LLM chat assistant via Ollama") && NEW_KEYS+=("3")
  [ "$SCENARIO"  -eq 0 ] && NEW_ITEMS+=("Scenario Builder") && NEW_LABELS+=("Build & run automated scenarios") && NEW_KEYS+=("4")
  [ "$OFFENSIVE" -eq 0 ] && NEW_ITEMS+=("Offensive Tools")  && NEW_LABELS+=("Nmap vuln, Masscan, R-Shell, Deauth, Autopwn") && NEW_KEYS+=("5")

  if [ ${#NEW_ITEMS[@]} -gt 0 ]; then
    echo ""
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${GREEN}      NEW COMPONENTS AVAILABLE${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo ""

    for i in "${!NEW_ITEMS[@]}"; do
      if [ "${NEW_ITEMS[$i]}" = "Offensive Tools" ]; then
        echo -e "${RED}[${NEW_KEYS[$i]}] ${NEW_ITEMS[$i]}${NC}"
      else
        echo -e "${GREEN}[${NEW_KEYS[$i]}] ${NEW_ITEMS[$i]}${NC}"
      fi
      echo "    ${NEW_LABELS[$i]}"
      echo ""
    done

    echo -e "${CYAN}==================================================${NC}"
    echo -e "${YELLOW}Select components to install (example: 1 3 5)${NC}"
    echo -e "${YELLOW}Type 'all' to install everything${NC}"
    echo -e "${YELLOW}Or press ENTER to skip${NC}"
    echo -e "${CYAN}==================================================${NC}"

    IFS= read -r -p "Select: " selection </dev/tty

    INSTALL_AI_DETECT=0
    INSTALL_AI_TRAIN=0
    INSTALL_AI_CHAT=0
    INSTALL_SCENARIO=0
    INSTALL_OFFENSIVE=0

    if [ -n "$selection" ]; then
      if [ "$selection" = "all" ]; then
        [ "$AI_DETECT" -eq 0 ]  && INSTALL_AI_DETECT=1
        [ "$AI_TRAIN" -eq 0 ]   && INSTALL_AI_TRAIN=1
        [ "$AI_CHAT" -eq 0 ]    && INSTALL_AI_CHAT=1
        [ "$SCENARIO" -eq 0 ]   && INSTALL_SCENARIO=1
        [ "$OFFENSIVE" -eq 0 ] && INSTALL_OFFENSIVE=1
      else
        for num in $selection; do
          case $num in
            1) [ "$AI_DETECT" -eq 0 ]  && INSTALL_AI_DETECT=1 ;;
            2) [ "$AI_TRAIN" -eq 0 ]   && INSTALL_AI_TRAIN=1 ;;
            3) [ "$AI_CHAT" -eq 0 ]    && INSTALL_AI_CHAT=1 ;;
            4) [ "$SCENARIO" -eq 0 ]   && INSTALL_SCENARIO=1 ;;
            5) [ "$OFFENSIVE" -eq 0 ]  && INSTALL_OFFENSIVE=1 ;;
          esac
        done
      fi

      # Jalankan install component yang dipilih
      if [ "$INSTALL_AI_DETECT" -eq 1 ] || [ "$INSTALL_AI_TRAIN" -eq 1 ] || [ "$INSTALL_AI_CHAT" -eq 1 ] || [ "$INSTALL_SCENARIO" -eq 1 ] || [ "$INSTALL_OFFENSIVE" -eq 1 ]; then
        echo ""
        echo -e "${GREEN}[~] Installing selected components...${NC}"
        
        # Panggil ulang installer tapi mode silent component only
        KECEMBUNG_UPDATE_MODE=1 bash "$HOME/.kecembung/install.sh"
      fi
    fi
  fi

  echo ""
  echo "[✔] Update selesai"
  echo "[~] Restarting KECEMBUNG..."
  sleep 2
  exec "$0"
}

