        fi

        echo -e "${CYAN}=========================${NC}"
        echo -e "${YELLOW}     STORAGE MODE${NC}"
        echo -e "${CYAN}=========================${NC}"
        echo "1. Local Mode"
        echo "2. USB Mode"
        echo "3. Installer"
        echo "4. Save Log"
        echo "5. USB Tools"
        echo "6. Kembali"
        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " smode || continue

        case $smode in
          1) cmd_storage_local ;;
          2) cmd_storage_usb ;;
          3) cmd_storage_install ;;
          4) cmd_storage_save_log ;;

          5)
            if [ "$INTERRUPTED" -eq 1 ]; then
              INTERRUPTED=0
              break
            fi

            while true; do

              if [ "$RETURN_TO_MAIN" -eq 1 ]; then
                break
              fi

              echo -e "${CYAN}=========================${NC}"
              echo -e "${GREEN}      USB TOOLS${NC}"
              echo -e "${CYAN}=========================${NC}"
              echo "1. Detect USB"
              echo "2. Select USB"
              echo "3. Create Workspace"
              echo "4. Read Data"
              echo "5. Delete Data"
              echo "6. Kembali"
              echo -e "${CYAN}=========================${NC}"

              IFS= read -r -p "Pilih menu: " usbmenu || continue

              case $usbmenu in
                1) cmd_usb_detect ;;
                2) cmd_usb_select ;;
                3) cmd_usb_workspace ;;
                4) cmd_usb_read ;;
                5) cmd_usb_delete ;;
                6) break ;;
              esac

            done
            ;;

          6) break ;;
        esac

      done
      ;;

    # =====================
    # 🤖 AI TOOLS
    # =====================
    menu_ai)
      while true; do

        if [ "$RETURN_TO_MAIN" -eq 1 ]; then
          break
        fi

        # build AI submenu dinamis
        ai_items=()
        ai_actions=()

        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Detect Webcam (All)")    && ai_actions+=("cmd_ai_webcam_all")
        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Detect Webcam (Person)") && ai_actions+=("cmd_ai_webcam_person")
        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Detect CCTV (RTSP)")     && ai_actions+=("cmd_ai_rtsp")
        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Detect Image File")      && ai_actions+=("cmd_ai_image")
        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Detect Video File")      && ai_actions+=("cmd_ai_video")
        [ "$AI_TRAIN_FLAG"  -eq 1 ] && ai_items+=("Custom AI Train")        && ai_actions+=("cmd_ai_train")
        [ "$AI_DETECT_FLAG" -eq 1 ] && ai_items+=("Custom AI Run")          && ai_actions+=("cmd_ai_run")
        [ "$AI_CHAT_FLAG"   -eq 1 ] && ai_items+=("AI Chat")                && ai_actions+=("menu_ai_chat")

        echo -e "${CYAN}=========================${NC}"
        echo -e "${GREEN}        AI TOOLS${NC}"
        echo -e "${CYAN}=========================${NC}"

        for i in "${!ai_items[@]}"; do
          echo "$((i+1)). ${ai_items[$i]}"
        done

        echo "$((${#ai_items[@]}+1)). Kembali"
        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " aimenu || continue

        if ! [[ "$aimenu" =~ ^[0-9]+$ ]]; then
          echo -e "${RED}Invalid option${NC}"
          continue
        fi

        if [ "$aimenu" -eq "$((${#ai_items[@]}+1))" ]; then
          break
        fi

        ai_action="${ai_actions[$((aimenu-1))]}"

        if [ -z "$ai_action" ]; then
          echo -e "${RED}Invalid option${NC}"
          continue
        fi

        case "$ai_action" in

          cmd_ai_webcam_all)    cmd_ai_webcam_all ;;
          cmd_ai_webcam_person) cmd_ai_webcam_person ;;
          cmd_ai_rtsp)          cmd_ai_rtsp ;;
          cmd_ai_image)         cmd_ai_image ;;
          cmd_ai_video)         cmd_ai_video ;;
          cmd_ai_train)         cmd_ai_train ;;
          cmd_ai_run)           cmd_ai_run ;;

          menu_ai_chat)
            while true; do

              if [ "$RETURN_TO_MAIN" -eq 1 ]; then
                break
              fi

              echo -e "${CYAN}=========================${NC}"
              echo -e "${GREEN}        AI CHAT${NC}"
              echo -e "${CYAN}=========================${NC}"
              echo "1. Start Chat"
              echo "2. Model Manager"
              echo "3. AI History"
              echo "4. AI Status"
              echo "5. Clear History"
              echo "6. Kembali"
              echo -e "${CYAN}=========================${NC}"

              IFS= read -r -p "Pilih menu: " aichat || continue

              case $aichat in
                1) cmd_ai_chat_start ;;

                2)
                  while true; do

                    echo "$(date +%s)" > "$WATCHDOG_FILE"

                    if [ "$RETURN_TO_MAIN" -eq 1 ]; then
                      break
                    fi

                    echo -e "${CYAN}=========================${NC}"
                    echo -e "${GREEN}      MODEL MANAGER${NC}"
                    echo -e "${CYAN}=========================${NC}"
                    echo "1. Download Model"
                    echo "2. List Installed Models"
                    echo "3. Delete Model"
                    echo "4. Kembali"
                    echo -e "${CYAN}=========================${NC}"

                    IFS= read -r -p "Pilih menu: " modelmenu || continue

                    case $modelmenu in
                      1) cmd_ai_download_model ;;
                      2) cmd_ai_list_models ;;
                      3) cmd_ai_delete_model ;;
                      4) break ;;
                      *) echo -e "${RED}Invalid option${NC}" ;;
                    esac

                  done
                  ;;

                3) cmd_ai_history ;;
                4) cmd_ai_status ;;
                5) cmd_ai_clear_history ;;
                6) break ;;
                *) echo -e "${RED}Invalid option${NC}" ;;
              esac

            done
            ;;

        esac

      done
      ;;

    # =====================
    # 📦 CUSTOM SCENARIO
    # =====================
    menu_scenario)
      while true; do

        if [ "$RETURN_TO_MAIN" -eq 1 ]; then
          break
        fi

        echo -e "${CYAN}=========================${NC}"
        echo -e "${CYAN}     CUSTOM SCENARIO${NC}"
        echo -e "${CYAN}=========================${NC}"
        echo "1. Jalankan Scenario"
        echo "2. Buat Scenario Baru"
        echo "3. Kembali"
        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " sub || continue

        case $sub in

          1)
            shopt -s nullglob
            files=("$SCENARIO_DIR"/*.sh)
            shopt -u nullglob

            if [ ${#files[@]} -eq 0 ]; then
              echo "[!] Tidak ada scenario"
              continue
            fi

            echo -e "${CYAN}=========================${NC}"
            echo -e "${CYAN}   DAFTAR SCENARIO${NC}"
            echo -e "${CYAN}=========================${NC}"

            for i in "${!files[@]}"; do
              echo "$i. $(basename "${files[$i]}")"
            done

            echo -e "${CYAN}=========================${NC}"

            read -p "Pilih scenario: " pilih

            if [ -n "${files[$pilih]}" ]; then
              echo "[~] Menjalankan scenario..."
              run_scenario_file "${files[$pilih]}"
              echo "[✔] Selesai"
              log_save "Run Scenario $(basename "${files[$pilih]}")"
            else
              echo "[!] Pilihan tidak valid"
            fi
            ;;

          2)
            if [ -f "$SCENARIO_BUILDER" ]; then
              bash "$SCENARIO_BUILDER"
            else
              echo "[!] scenario_builder.sh tidak ditemukan"
            fi
            ;;

          3) break ;;

        esac

      done
      ;;

    # =====================
    # 🚪 EXIT
    # =====================
    do_exit)
      echo -e "${RED}Exiting KECEMBUNG...${NC}"

      pkill -P $$ 2>/dev/null

      sleep 1
      clear
      break
      ;;

  esac

done
