# =========================

run_scenario_file() {
  local file="$1"

  if [ ! -f "$file" ]; then
    echo "[!] Scenario tidak ditemukan: $file"
    return 1
  fi

  echo "[~] Running scenario: $(basename "$file")"

  local line=0

  while IFS= read -r cmd || [ -n "$cmd" ]; do
    ((line++))

    [ -z "$cmd" ] && continue
    [[ "$cmd" =~ ^# ]] && continue

    cmd=$(echo "$cmd" | xargs)

    [ -z "$cmd" ] && continue

    echo "[SCENARIO:$line] $cmd"

    run_command "$cmd"

    if [ "$RECOVERY_MODE" -eq 1 ]; then
      echo "[!] Recovery aktif → stop scenario"
      break
    fi

  done < "$file"

  echo "[✔] Scenario selesai"
  return 0
}

