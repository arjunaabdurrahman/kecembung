cmd_ai_train() {
  init_storage
  echo "[~] Mencari data.yaml..."
  
  if [ ! -f "$HOME/ai_train.py" ]; then
    echo "[!] ai_train.py tidak ditemukan"
    return
  fi
  
  if ! command -v dialog >/dev/null 2>&1; then
    echo "[!] dialog belum terinstall"
    return
  fi

  mapfile -t files < <(find "$HOME" -maxdepth 5 -type f -name "data.yaml")

  if [ ${#files[@]} -eq 0 ]; then
    echo "[!] Tidak ditemukan data.yaml"
    return
  fi

  options=()
  for i in "${!files[@]}"; do
    options+=($i "${files[$i]}")
  done
  
  choice=$(dialog --menu "Pilih data.yaml:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  data="${files[$choice]}"

  echo "[!] Kamu pilih: $data"
  read -p "Ketik YES untuk training: " confirm

  if [ "$confirm" != "YES" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  "$PYTHON" "$HOME/ai_train.py" "$data"

  log_save "Custom AI Training"
}

cmd_ai_run() {
  init_storage
  echo "[~] Pilih model folder..."
  
   if [ ! -f "$HOME/ai_detect.py" ]; then
    echo "[!] ai_detect.py tidak ditemukan"
    return
  fi
  
  if ! command -v dialog >/dev/null 2>&1; then
    echo "[!] dialog belum terinstall"
    return
  fi

  mapfile -t dirs < <(find "$HOME" -maxdepth 5 -type d -path "*/runs/*")

  if [ ${#dirs[@]} -eq 0 ]; then
    echo "[!] Tidak ada model"
    return
  fi

  options=()
  for i in "${!dirs[@]}"; do
    options+=($i "${dirs[$i]}")
  done
  
  choice=$(dialog --menu "Pilih folder:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  selected="${dirs[$choice]}"
  model=$(find "$selected" -name "best.pt" | head -n 1)

  if [ ! -f "$model" ]; then
    echo "[!] Model tidak ditemukan"
    return
  fi

  echo "1. Webcam"
  echo "2. RTSP"
  read -p "Pilih: " mode

  if [ "$mode" = "1" ]; then
    src=0
  else
    read -p "RTSP URL: " src
  fi

  "$PYTHON" "$HOME/ai_detect.py" "$src" "$storage_path/captures" all "$model"

  log_save "Custom AI Run"
}

