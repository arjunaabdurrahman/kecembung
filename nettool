cmd_ai_train() {
  init_storage
  echo "[~] Mencari data.yaml..."

  if [ ! -f "$HOME/ai_train.py" ]; then
    echo "[!] ai_train.py tidak ditemukan"
    return
  fi

  mapfile -t files < <(find "$HOME" -type f -name "data.yaml" | sort)

  if [ ${#files[@]} -eq 0 ]; then
    echo "[!] Tidak ditemukan data.yaml"
    return
  fi

  options=()
  for i in "${!files[@]}"; do
    options+=("$i" "${files[$i]}")
  done

  choice=$(dialog --menu "Pilih data.yaml:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ] || ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo "[x] Dibatalkan / invalid selection"
    return
  fi

  data="${files[$choice]}"

  if [ -z "$data" ] || [ ! -f "$data" ]; then
    echo "[!] File data.yaml tidak valid"
    return
  fi

  echo "[!] Kamu pilih: $data"
  read -p "Ketik YES untuk training: " confirm

  if [ "$confirm" != "YES" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  $PYTHON "$HOME/ai_train.py" "$data"
  log_save "Custom AI Training"
}

cmd_ai_run() {
  init_storage
  if ! command -v dialog >/dev/null 2>&1; then
    echo "[!] dialog belum terinstall"
    echo "[~] Install dengan Installer di Storage Mode atau sudo apt install dialog"
    return
  fi
  
  echo "[~] Pilih model folder..."

  if [ ! -f "$HOME/ai_detect.py" ]; then
    echo "[!] ai_detect.py tidak ditemukan"
    return
  fi

  command -v dialog >/dev/null 2>&1 || {
    echo "[!] dialog tidak tersedia"
    return
  }

  mapfile -t dirs < <(find "$HOME" -maxdepth 6 -type d -path "*/runs/*" 2>/dev/null | sort)

  if [ ${#dirs[@]} -eq 0 ]; then
    echo "[!] Tidak ada model runs ditemukan"
    return
  fi

  options=()
  for i in "${!dirs[@]}"; do
    options+=("$i" "${dirs[$i]}")
  done

  choice=$(dialog --menu "Pilih folder model:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ] || ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo "[x] Dibatalkan / invalid selection"
    return
  fi

  selected="${dirs[$choice]}"

  if [ -z "$selected" ] || [ ! -d "$selected" ]; then
    echo "[!] Folder tidak valid"
    return
  fi

  model=$(find "$selected" -name "best.pt" | head -n 1)

  if [ -z "$model" ]; then
    echo "[!] Model best.pt tidak ditemukan"
    return
  fi

  echo "[✔] Model terpilih: $model"

  echo "1. Webcam"
  echo "2. RTSP"
  read -p "Pilih input source: " mode

  case "$mode" in
    1) src=0 ;;
    2)
      read -p "RTSP URL: " src
      [ -z "$src" ] && { echo "[!] RTSP kosong"; return; }
      ;;
    *) echo "[!] Invalid pilihan"; return ;;
  esac

  echo "[~] Running AI model..."
  $PYTHON "$HOME/ai_detect.py" "$src" "$storage_path/captures" all "$model"

  log_save "Custom AI Run"
}

# =========================
# 📦 SCENARIO RUNNER
