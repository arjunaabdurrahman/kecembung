# =========================
# 🔁 PROCESS TRACKING
# =========================

trap_ctrlc() {

  # anti spam ctrl+c
  if [ "$RECOVERY_MODE" -eq 1 ]; then
    return
  fi

  echo ""
  echo "[!] CTRL+C DETECTED → RETURN TO MAIN MENU"

  INTERRUPTED=1
  RECOVERY_MODE=1
  RETURN_TO_MAIN=1

  # kill AI/main process
  if [ "$CURRENT_PID" -ne 0 ] 2>/dev/null; then
    kill_process "$CURRENT_PID"
    wait "$CURRENT_PID" 2>/dev/null
    CURRENT_PID=0
  fi

  # kill background child
  if [ -n "$CURRENT_CHILD" ]; then
    kill -TERM -"$CURRENT_CHILD" 2>/dev/null
    sleep 0.3
    kill -TERM -"$CURRENT_CHILD" 2>/dev/null
    sleep 0.3

    if kill -0 "$CURRENT_CHILD" 2>/dev/null; then
        kill -KILL -"$CURRENT_CHILD" 2>/dev/null
    fi
    wait "$CURRENT_CHILD" 2>/dev/null
    CURRENT_CHILD=""
  fi

  # kill semua child process script
  pkill -TERM -P $$ 2>/dev/null

  sleep 0.2
}

trap trap_ctrlc SIGINT

reset_state() {
  INTERRUPTED=0
  RETURN_TO_MAIN=0
  RECOVERY_MODE=0
  CRASH_FLAG=0

  # kill sisa child process kalau ada
  if [ -n "$CURRENT_CHILD" ]; then
    kill_process "$CURRENT_CHILD"
    CURRENT_CHILD=""
  fi

  CURRENT_PID=0
}

# =========================
# 🛡️ SELF-HEAL SAFE RUNNER
# =========================

safe_run() {
  local timeout_sec="$1"
  shift
  local cmd=("$@")

  CURRENT_CHILD=""

  # jalankan process dalam group sendiri
  setsid "${cmd[@]}" &
  CURRENT_CHILD=$!

  local status=0

  # timeout mode
  if [ "$timeout_sec" -gt 0 ]; then

    for ((i=0; i<timeout_sec; i++)); do

      # kalau sudah mati → langsung keluar
      if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
        wait "$CURRENT_CHILD" 2>/dev/null
        status=$?
        CURRENT_CHILD=""
        return $status
      fi

      sleep 1

      # kalau user interrupt
      if [ "$RECOVERY_MODE" -eq 1 ]; then
        kill -TERM -"$CURRENT_CHILD" 2>/dev/null
        sleep 0.3

  	if kill -0 "$CURRENT_CHILD" 2>/dev/null; then
    	    kill -KILL -"$CURRENT_CHILD" 2>/dev/null
	fi
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""
        return 1
      fi
    done

    echo "[!] SAFE RUN: timeout (${timeout_sec}s)"

    # kill entire process group
    kill -9 -"$CURRENT_CHILD" 2>/dev/null
    wait "$CURRENT_CHILD" 2>/dev/null

    CURRENT_CHILD=""
    return 124
  fi

  # NO TIMEOUT MODE
  wait "$CURRENT_CHILD"
  status=$?

  CURRENT_CHILD=""

  if [ $status -ne 0 ]; then
    echo "[!] SAFE RUN: error (code $status)"
  fi

  return $status
}

# =========================
# 🐶 WATCHDOG SYSTEM
# =========================
watchdog_loop() {
  local recovery_lock=0

  while true; do
    sleep 2

    WATCHDOG_TIMEOUT=10

    # kalau lagi recovery, skip penuh
    if [ "$RECOVERY_MODE" -eq 1 ]; then
      continue
    fi

    # file harus ada
    if [ ! -f "$WATCHDOG_FILE" ]; then
      continue
    fi

    last=$(cat "$WATCHDOG_FILE" 2>/dev/null)

    # validasi numeric
    if ! [[ "$last" =~ ^[0-9]+$ ]]; then
      continue
    fi

    now=$(date +%s)
    diff=$((now - last))

    # safety guard
    if [ "$diff" -lt 0 ]; then
      continue
    fi

    if [ "$diff" -ge "$WATCHDOG_TIMEOUT" ]; then

      # anti double trigger
      if [ "$recovery_lock" -eq 1 ]; then
        continue
      fi
      recovery_lock=1

      echo ""
      echo "[!] WATCHDOG: system freeze terdeteksi (${diff}s)"

      # kill child process
      if [ -n "$CURRENT_CHILD" ]; then
        kill_process "$CURRENT_CHILD"
        wait "$CURRENT_CHILD" 2>/dev/null
        CURRENT_CHILD=""
      fi

      # kill main process
      if [ "$CURRENT_PID" -ne 0 ] 2>/dev/null; then
        kill_process "$CURRENT_PID"
        wait "$CURRENT_PID" 2>/dev/null
        CURRENT_PID=0
      fi

      pkill -P $$ 2>/dev/null

      RETURN_TO_MAIN=1
      INTERRUPTED=1

      # write recovery heartbeat (beda marker)
      echo "$(date +%s)" > "$WATCHDOG_FILE"

      log_save "WATCHDOG TRIGGERED (freeze ${diff}s)"
    fi

  done
}

