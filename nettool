    storage_path="$HOME/nettools_logs"
  else
    if [ -z "$USB_PATH" ]; then
      storage_mode="local"
      storage_path="$HOME/nettools_logs"
    else
      storage_path="$USB_PATH/NETTOOLS"
    fi
  fi

  if [ -z "$storage_path" ] || [ "$storage_path" = "/" ]; then
    storage_path="$HOME/nettools_logs"
  fi

  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"
}

log_save() {

  init_storage

  if [ ! -d "$storage_path" ]; then
    echo "[!] Storage path invalid"
    return 1
  fi

  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$storage_path/nettools_log.txt"
}

