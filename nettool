cmd_ai_train() {
  init_storage
  echo "[~] Mencari data.yaml..."

  mkdir -p "$storage_path/captures"

  if [ ! -x "$PYTHON" ]; then
    echo "[!] Python env tidak siap"
    return
  fi

  if [ ! -f "$HOME/ai_train.py" ]; then
    echo "[!] ai_train.py tidak ditemukan"
    return
  fi

  if ! command -v dialog >/dev/null 2>&1; then
    echo "[!] dialog belum terinstall"
    return
  fi

  mapfile -t files < <(find "$HOME" -maxdepth 5 -type f -name "data.yaml")

  if [ ${#files[@]} -eq 0 ]; then
    echo "[!] Tidak ditemukan data.yaml"
    return
  fi

  options=()
  for i in "${!files[@]}"; do
    options+=($i "${files[$i]}")
  done

  choice=$(dialog --menu "Pilih data.yaml:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ] || ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo "[!] Invalid selection"
    return
  fi

  if [ -z "${files[$choice]}" ]; then
    echo "[!] Data tidak valid"
    return
  fi

  data="${files[$choice]}"

  echo "[!] Kamu pilih: $data"
  read -p "Ketik YES untuk training: " confirm

  if [ "$confirm" != "YES" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  safe_ai 60 "$PYTHON" "$HOME/ai_train.py" "$data"

  log_save "Custom AI Training"
}

cmd_ai_run() {
  init_storage
  echo "[~] Pilih model folder..."

  mkdir -p "$storage_path/captures"

  if [ ! -x "$PYTHON" ]; then
    echo "[!] Python env tidak siap"
    return
  fi

  if [ ! -f "$HOME/ai_detect.py" ]; then
    echo "[!] ai_detect.py tidak ditemukan"
    return
  fi

  if ! command -v dialog >/dev/null 2>&1; then
    echo "[!] dialog belum terinstall"
    return
  fi

  mapfile -t models < <(find "$HOME" -maxdepth 4 -type f -name "best.pt")

  if [ ${#models[@]} -eq 0 ]; then
    echo "[!] Tidak ada model"
    return
  fi

  options=()
  for i in "${!models[@]}"; do
    options+=($i "${models[$i]}")
  done

  choice=$(dialog --menu "Pilih model:" 20 80 10 "${options[@]}" 2>&1 >/dev/tty)

  if [ -z "$choice" ] || ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo "[!] Invalid selection"
    return
  fi

  model="${models[$choice]}"

  if [ ! -f "$model" ]; then
    echo "[!] Model tidak valid"
    return
  fi

  echo "1. Webcam"
  echo "2. RTSP"
  read -p "Pilih: " mode

  if [ "$mode" = "1" ]; then
    src=0
  else
    read -p "RTSP URL: " src
    if [[ -z "$src" || ! "$src" =~ ^rtsp:// ]]; then
      echo "[!] RTSP tidak valid"
      return
    fi
  fi

  safe_ai 60 "$PYTHON" "$HOME/ai_detect.py" "$src" "$storage_path/captures" all "$model"

  log_save "Custom AI Run"
}

