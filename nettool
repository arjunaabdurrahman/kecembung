# =========================
# 🎨 COLORS
# =========================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

set +e
set -o pipefail

CURRENT_PID=0
CURRENT_CHILD=""
RECOVERY_MODE=0
INTERRUPTED=0
RETURN_TO_MAIN=0
CRASH_FLAG=0

kill_process() {
  local pid="$1"

  if [ -z "$pid" ]; then
    return
  fi

  # coba kill normal dulu
  kill "$pid" 2>/dev/null

  # tunggu dikit
  sleep 0.5

  # kalau masih hidup, baru paksa
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null
  fi
}

# =========================
# SAFE AI RUN 
# =========================

safe_ai() {
  local timeout="$1"
  shift

  if [ "$INTERRUPTED" -eq 1 ]; then
    echo "[!] SAFE AI: dibatalkan (CTRL+C)"
    INTERRUPTED=0
    return 1
  fi

  set +e

  # jalankan dalam process group sendiri
  if [ "$timeout" -eq 0 ]; then
    setsid "$@" &
  else
    timeout "$timeout" setsid "$@" &
  fi

  CURRENT_PID=$!

  # tunggu process selesai (tanpa polling manual)
  wait "$CURRENT_PID"
  local status=$?

  CURRENT_PID=0

  set -e

  # interpretasi status
  if [ $status -eq 124 ]; then
    echo "[!] SAFE AI: timeout ($timeout detik)"
  elif [ $status -ne 0 ]; then
    echo "[!] SAFE AI: crash (code $status)"
  fi

  return $status
}

# =========================
# SAFE MENU RUN 
# =========================
safe_menu() {
  set +e
  "$@"
  local status=$?
  set -e

  if [ $status -ne 0 ]; then
    echo "[!] SAFE MENU: error di menu command"
  fi

  return $status
}

# =========================
# SAFE BACKGROUND RUN 
# =========================
safe_bg() {
  set +e

  "$@" &
  local pid=$!

  set -e

  CURRENT_CHILD="$pid"

  echo "[~] Background process started (PID: $pid)"

  # update watchdog sekali biar gak dianggap freeze
  echo "$(date +%s)" > "$WATCHDOG_FILE"

  echo $pid
  return 0
}

