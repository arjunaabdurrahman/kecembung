cmd_scenario_list() {
  echo "[~] Loading scenarios..."

  mapfile -t scenarios < <(find "$HOME/nettools_scenarios" -type f)

  if [ ${#scenarios[@]} -eq 0 ]; then
    echo "[!] No scenario found"
    return
  fi

  echo ""
  echo "Available Scenarios:"
  for i in "${!scenarios[@]}"; do
    name=$(basename "${scenarios[$i]}")
    echo "$((i+1)). $name"
  done

  read -p "Select scenario: " choice

  index=$((choice-1))

  if [ -z "${scenarios[$index]}" ]; then
    echo "[!] Invalid selection"
    return
  fi

  echo "[~] Running scenario..."
  bash "${scenarios[$index]}"

  log_save "Run Scenario: $(basename "${scenarios[$index]}")"
}

init_storage() {

  # MODE LOCAL
  if [ "$storage_mode" = "local" ]; then
    storage_path="$HOME/nettools_logs"

  # MODE USB
  else
    # validasi USB
    if [ -z "$USB_PATH" ] || [ ! -d "$USB_PATH" ]; then
      echo "[!] USB disconnected/invalid → fallback to local mode"
      storage_mode="local"
      storage_path="$HOME/nettools_logs"
    else
      storage_path="$USB_PATH/NETTOOLS"
    fi
  fi

  # safety final check (anti root overwrite)
  if [ -z "$storage_path" ] || [ "$storage_path" = "/" ]; then
    echo "[!] CRITICAL: invalid storage path detected → forcing local"
    storage_mode="local"
    storage_path="$HOME/nettools_logs"
  fi

  # ensure directories exist
  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"
}

log_save() {
  # pastikan storage sudah benar sebelum apa pun
  init_storage

  # safety check
  if [ -z "$storage_path" ] || [ ! -d "$storage_path" ]; then
    echo "[!] Storage path invalid, log skipped"
    return
  fi

  LOG_FILE="$storage_path/nettools_log.txt"

  # rotate log jika terlalu besar (>5MB)
  if [ -f "$LOG_FILE" ]; then
    size=$(stat -c%s "$LOG_FILE" 2>/dev/null)

    if [ "$size" -gt 5000000 ]; then
      mv "$LOG_FILE" "$storage_path/nettools_log_old.txt"
      echo "[~] Log rotated"
    fi
  fi

  mkdir -p "$storage_path"

  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

