#!/bin/bash

# =========================
# 🎨 COLORS
# =========================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# CTRL + C RAPI
trap "echo -e '\n[!] Safe exit activated'; exit 0" SIGINT
trap 'echo "[!] Warning: command error detected (ignored)"' ERR

# =========================
# 🧠 PYTHON ENV AUTO DETECT + AUTO CREATE
# =========================
ENV_PATH="$HOME/nettool-env"

if [ ! -d "$ENV_PATH" ] || [ ! -f "$ENV_PATH/bin/python" ] || \
   [ ! -f "$ENV_PATH/bin/pip" ]; then

  echo "[~] AI environment rusak / tidak lengkap, rebuild..."

  rm -rf "$ENV_PATH"

  python3 -m venv "$ENV_PATH"

  "$ENV_PATH/bin/pip" install --upgrade pip
  "$ENV_PATH/bin/pip" install ultralytics opencv-python --no-cache-dir
  "$ENV_PATH/bin/pip" install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

  rm -rf ~/.cache/pip
fi

PYTHON="$ENV_PATH/bin/python"

# =========================
# 🔐 PASSWORD PROTECTION (SECURE)
# =========================

PASS_FILE="$HOME/.nettool_pass"

if [ ! -f "$PASS_FILE" ]; then
  echo "[!] Password belum diset. Jalankan installer dulu."
  exit 1
fi

echo ""
read -s -p "Masukkan Password NETTOOLS: " input
echo ""

# cek kosong
if [ -z "$input" ]; then
  echo "[!] Password tidak boleh kosong"
  exit 1
fi

# hash input
INPUT_HASH=$(echo -n "$input" | sha256sum | awk '{print $1}')

# ambil hash tersimpan
STORED_HASH=$(cat "$PASS_FILE")

# validasi
if [ "$INPUT_HASH" != "$STORED_HASH" ]; then
  echo "[!] Password salah"
  exit 1
fi

echo "[✔] Akses diterima"
echo ""

# =========================
# 💾 STORAGE SYSTEM
# =========================
storage_mode="local"
storage_path="$HOME/nettools_logs"

USB_PATH=""
USB_SELECTED=0

SCENARIO_DIR="$HOME/nettools_scenarios"
mkdir -p "$SCENARIO_DIR"

# =========================
# COMMAND MAP
# =========================


# =========================
# COMMAND MAP - IP TOOLS
# =========================

cmd_lihat_ip() {
  ip -brief address
}

cmd_scan_jaringan() {
  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24
  nmap -sn "$net"
}

cmd_ping_ip() {
  read -p "Target IP: " target
  ping -c 4 "$target"
}

cmd_set_ip_manual() {
  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eno|eth" | head -n 1 | cut -d: -f1)

  read -p "IP (contoh 192.168.1.10/24): " ipbaru
  read -p "Gateway: " gateway

  nmcli con mod "$koneksi" ipv4.addresses "$ipbaru"
  nmcli con mod "$koneksi" ipv4.gateway "$gateway"
  nmcli con mod "$koneksi" ipv4.method manual
  nmcli con up "$koneksi"
}

cmd_routing() {
  ip route
  echo ""
  echo "[~] Gateway:"
  ip route | grep default

  echo ""
  echo "[~] Interface Aktif:"
  ip -brief address | grep UP
}

cmd_dns_check() {
  echo "[~] DNS Aktif:"
  resolvectl status | grep "DNS Servers" -A2
}

cmd_internet_check() {
  ping -c 2 8.8.8.8
}

cmd_scan_ssh() {
  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24
  nmap -p 22 --open "$net"
}

cmd_ssh_connect() {
  read -p "Target IP: " target
  read -p "User: " user
  ssh "$user@$target"
}

cmd_reset_ip() {
  echo "[~] Reset IP ke otomatis (DHCP)..."

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eth|eno" | head -n 1 | cut -d: -f1)

  if [ -z "$koneksi" ]; then
    echo "[!] Tidak ada koneksi aktif"
  else
    echo "[~] Koneksi: $koneksi"

    sudo nmcli con mod "$koneksi" ipv4.method auto
    sudo nmcli con mod "$koneksi" ipv4.addresses ""
    sudo nmcli con mod "$koneksi" ipv4.gateway ""
    sudo nmcli con mod "$koneksi" ipv4.dns ""

    sudo nmcli con down "$koneksi"
    sudo nmcli con up "$koneksi"

    echo "[✔] IP berhasil di reset"
  fi
}

# =========================
# COMMAND MAP - TCP TOOLS
# =========================

cmd_tcp_scan_port() {
  read -p "Target: " t
  nmap -sT "$t"
}

cmd_tcp_service_detection() {
  read -p "Target: " t
  nmap -sV "$t"
}

cmd_tcp_range_scan() {
  read -p "Target: " t
  nmap -p 1-1000 "$t"
}

cmd_tcp_specific_port() {
  read -p "Target: " t
  read -p "Port: " p
  nmap -p "$p" "$t"
}

cmd_tcp_local_ports() {
  ss -tuln
}

cmd_tcp_banner_grab() {
  read -p "Target: " t
  nc "$t" 80
}

# =========================
# COMMAND MAP - STORAGE
# =========================

cmd_storage_local() {
  storage_mode="local"
  storage_path="$HOME/nettools_logs"
  mkdir -p "$storage_path"
  echo "Local active"
}

cmd_storage_usb() {
  storage_mode="usb"
  storage_path="$USB_PATH/NETTOOLS"
  mkdir -p "$storage_path"
  echo "USB active"
}

cmd_storage_install() {
  read -p "Install apa? (contoh: nmap): " pkg

  if [ -z "$pkg" ]; then
    echo "[!] Tidak ada input"
  else
    sudo apt update
    sudo apt install -y "$pkg"

    if [ $? -eq 0 ]; then
      echo "[✔] Install berhasil"
      log_save "Install $pkg"
    else
      echo "[!] Install gagal"
    fi
  fi
}

cmd_storage_save_log() {
  read -p "Ketik YES untuk save log: " confirm

  if [ "$confirm" != "YES" ]; then
    echo "[x] Dibatalkan"
    return
  fi

  init_storage

  LOG_SRC="$HOME/nettools_logs/nettools_log.txt"

  if [ ! -f "$LOG_SRC" ]; then
    echo "[!] Log file belum ada, belum bisa disimpan"
    return
  fi

  # safety storage check
  if [ -z "$storage_path" ] || [ ! -d "$storage_path" ]; then
    echo "[!] Storage tidak valid"
    return
  fi

  mkdir -p "$storage_path"

  cp "$LOG_SRC" "$storage_path/" 2>/dev/null

  if [ $? -eq 0 ]; then
    echo "[✔] Log berhasil disimpan"
  else
    echo "[!] Gagal menyimpan log"
  fi
}

# =========================
# COMMAND MAP - USB TOOLS
# =========================

cmd_usb_detect() {
  echo "[~] Available USB devices:"
  lsblk -o NAME,SIZE,MOUNTPOINT | grep "/media\|/run/media"
}

cmd_usb_select() {
  echo "[~] Detecting USB devices..."

  # ambil hanya removable + mount point valid
  mapfile -t usb_list < <(
    lsblk -o NAME,SIZE,MOUNTPOINT,RM,TRAN,TYPE \
    | awk '$4==1 && $3!="" && ($5=="usb" || $5=="") {print $3}'
  )

  if [ ${#usb_list[@]} -eq 0 ]; then
    echo "[!] No USB devices detected"
    USB_SELECTED=0
    return
  fi

  echo ""
  echo "[~] Available USB mounts:"
  for i in "${!usb_list[@]}"; do
    echo "$i. ${usb_list[$i]}"
  done

  echo ""
  read -p "Select USB index: " idx

  # VALIDASI INPUT
  if [ -z "$idx" ]; then
    echo "[!] No selection"
    USB_SELECTED=0
    return
  fi

  if ! [[ "$idx" =~ ^[0-9]+$ ]]; then
    echo "[!] Invalid selection (not number)"
    USB_SELECTED=0
    return
  fi

  if [ -z "${usb_list[$idx]}" ]; then
    echo "[!] Invalid index"
    USB_SELECTED=0
    return
  fi

  USB_PATH="${usb_list[$idx]}"
  USB_SELECTED=1

  echo "[✔] USB selected: $USB_PATH"

  # safety check tambahan
  if [[ "$USB_PATH" != /media/* && "$USB_PATH" != /run/media/* ]]; then
    echo "[!] WARNING: unusual mount path"
  fi
}

cmd_usb_workspace() {
  mkdir -p "$USB_PATH/NETTOOLS/logs"
  mkdir -p "$USB_PATH/NETTOOLS/reports"
  echo "[✔] Workspace created"
}

cmd_usb_read() {
  ls -R "$USB_PATH"
}

cmd_usb_delete() {
  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] No USB selected"
    return
  fi

  if [ ! -d "$USB_PATH" ]; then
    echo "[!] Invalid USB path"
    return
  fi

  echo "[!] WARNING: This will delete ALL files in:"
  echo "    $USB_PATH"
  read -p "Type YES to confirm: " confirm

  if [ "$confirm" != "YES" ]; then
    echo "[x] Cancelled"
    return
  fi

  # safety double-check
  if [ -z "$USB_PATH" ] || [ "$USB_PATH" = "/" ]; then
    echo "[!] Unsafe path detected, abort"
    return
  fi

  rm -rf "$USB_PATH"/* 2>/dev/null
  sync

  echo "[✔] Deleted successfully"

  if [ "$(ls -A "$USB_PATH" 2>/dev/null)" ]; then
    echo "[!] WARNING: Some files still exist"
  else
    echo "[✔] VERIFIED: USB is empty"
  fi
}

