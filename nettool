#!/bin/bash

# =========================
# 🎨 COLORS
# =========================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

set -e
set -o pipefail

# =========================
# 🛑 CTRL+C HANDLER
# =========================

INTERRUPTED=0

trap_ctrlc() {
  echo ""
  echo -e "${YELLOW}[!] CTRL+C terdeteksi, kembali ke menu...${NC}"
  sleep 1
  clear
  INTERRUPTED=1
}

trap trap_ctrlc SIGINT
stty -echoctl 2>/dev/null

# =========================
# 🧠 PYTHON ENV AUTO DETECT + AUTO CREATE
# =========================
ENV_PATH="$HOME/nettool-env"

if [ ! -d "$ENV_PATH" ] || [ ! -f "$ENV_PATH/bin/python" ] || [ ! -f "$ENV_PATH/bin/pip" ]; then
    echo "[~] AI environment tidak valid, memperbaiki..."

    if [[ "$ENV_PATH" == "$HOME/"* ]]; then
      rm -rf "$ENV_PATH"
    fi

    python3 -m venv "$ENV_PATH" || {
      echo "[!] Gagal membuat virtual environment"
      exit 1
}

"$ENV_PATH/bin/pip" install --upgrade pip
"$ENV_PATH/bin/pip" install --upgrade pip || exit 1
"$ENV_PATH/bin/pip" install ultralytics opencv-python --no-cache-dir || exit 1
"$ENV_PATH/bin/pip" install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu || exit 1
if ! "$ENV_PATH/bin/python" -c "import ultralytics, cv2" >/dev/null 2>&1; then
  echo "[!] Dependency Python tidak lengkap"
  exit 1
fi

fi

PYTHON="$ENV_PATH/bin/python"
if [ ! -x "$PYTHON" ]; then
  echo "[!] Python environment tidak valid"
  exit 1
fi

if ! command -v sudo >/dev/null 2>&1; then
  echo "[!] sudo tidak tersedia"
  exit 1
fi

# =========================
# 🔐 PASSWORD PROTECTION (SECURE)
# =========================

PASS_FILE="$HOME/.nettool_pass"

# pastikan folder home valid dulu
PASS_DIR="$(dirname "$PASS_FILE")"
mkdir -p "$PASS_DIR"

if [ ! -f "$PASS_FILE" ]; then
  echo "[!] Password belum diset. Jalankan installer dulu."
  exit 1
fi

echo ""
read -s -p "Masukkan Password NETTOOLS: " input
echo ""

if [ -z "$input" ]; then
  echo "[!] Password tidak boleh kosong"
  exit 1
fi

INPUT_HASH=$(echo -n "$input" | sha256sum | awk '{print $1}')
read -r STORED_HASH < "$PASS_FILE"

if [ "$INPUT_HASH" != "$STORED_HASH" ]; then
  echo "[!] Password salah"
  exit 1
fi

echo "[✔] Akses diterima"
echo ""

# =========================
# 💾 STORAGE SYSTEM
# =========================
storage_mode="local"
storage_path="$HOME/nettools_logs"

USB_PATH=""
USB_SELECTED=0

SCENARIO_DIR="$HOME/nettools_scenarios"
mkdir -p "$SCENARIO_DIR"

init_storage() {
  if [ "$storage_mode" = "local" ]; then
    storage_path="$HOME/nettools_logs"
  else
    storage_path="$USB_PATH/NETTOOLS"
  fi
  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"  
}

log_save() {
  init_storage
  
  if [ -z "$storage_path" ]; then
    echo "[!] storage_path kosong, log dibatalkan"
    return
  fi

  mkdir -p "$storage_path"
  echo "[$(date)] $1" >> "$storage_path/nettools_log.txt"
}

# =========================
# COMMAND MAP
# =========================

# =========================
# COMMAND MAP - IP TOOLS
# =========================

cmd_lihat_ip() {
  ip -brief address
}

cmd_scan_jaringan() {
  if ! command -v nmap >/dev/null 2>&1; then
    echo "[!] nmap belum terinstall"
    return
  fi
  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24
  nmap -sn "$net"
}

cmd_ping_ip() {
  read -p "Target IP: " target
  ping -c 4 "$target"
}

cmd_set_ip_manual() {
  if ! command -v nmcli >/dev/null 2>&1; then
    echo "[!] nmcli tidak tersedia di sistem ini"
    return
  fi
  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eno|eth" | head -n 1 | cut -d: -f1)

  read -p "IP (contoh 192.168.1.10/24): " ipbaru
  read -p "Gateway: " gateway

  nmcli con mod "$koneksi" ipv4.addresses "$ipbaru"
  nmcli con mod "$koneksi" ipv4.gateway "$gateway"
  nmcli con mod "$koneksi" ipv4.method manual
  nmcli con up "$koneksi"
}

cmd_routing() {
  ip route
  echo ""
  echo "[~] Gateway:"
  ip route | grep default

  echo ""
  echo "[~] Interface Aktif:"
  ip -brief address | grep UP
}

cmd_dns_check() {
  echo "[~] DNS Aktif:"
  resolvectl status | grep "DNS Servers" -A2
}

cmd_internet_check() {
  ping -c 2 8.8.8.8
}

cmd_scan_ssh() {
  if ! command -v nmap >/dev/null 2>&1; then
    echo "[!] nmap belum terinstall"
    return
  fi
  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24
  nmap -p 22 --open "$net"
}

cmd_ssh_connect() {
  read -p "Target IP: " target
  read -p "User: " user
  ssh "$user@$target"
}

cmd_reset_ip() {
  if ! command -v nmcli >/dev/null 2>&1; then
    echo "[!] nmcli tidak tersedia di sistem ini"
    return
  fi
  echo "[~] Reset IP ke otomatis (DHCP)..."

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eth|eno" | head -n 1 | cut -d: -f1)

  if [ -z "$koneksi" ]; then
    echo "[!] Tidak ada koneksi aktif"
  else
    echo "[~] Koneksi: $koneksi"

    sudo nmcli con mod "$koneksi" ipv4.method auto
    sudo nmcli con mod "$koneksi" ipv4.addresses ""
    sudo nmcli con mod "$koneksi" ipv4.gateway ""
    sudo nmcli con mod "$koneksi" ipv4.dns ""

    sudo nmcli con down "$koneksi"
    sudo nmcli con up "$koneksi"

    echo "[✔] IP berhasil di reset"
  fi
}

# =========================
# COMMAND MAP - TCP TOOLS
# =========================

cmd_tcp_scan_port() {
  read -p "Target: " t
  nmap -sT "$t"
}

cmd_tcp_service_detection() {
  read -p "Target: " t
  nmap -sV "$t"
}

cmd_tcp_range_scan() {
  read -p "Target: " t
  nmap -p 1-1000 "$t"
}

cmd_tcp_specific_port() {
  read -p "Target: " t
  read -p "Port: " p
  nmap -p "$p" "$t"
}

cmd_tcp_local_ports() {
  ss -tuln
}

cmd_tcp_banner_grab() {
  if ! command -v nc >/dev/null 2>&1; then
    echo "[!] netcat tidak tersedia"
    return
  fi
  read -p "Target: " t
  nc "$t" 80
}

# =========================
# COMMAND MAP - STORAGE
# =========================

cmd_storage_local() {
  storage_mode="local"
  storage_path="$HOME/nettools_logs"
  mkdir -p "$storage_path"
  echo "Local active"
}

cmd_storage_usb() {
  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] USB belum dipilih"
    return
  fi
  storage_mode="usb"
  storage_path="$USB_PATH/NETTOOLS"
  mkdir -p "$storage_path"
  echo "USB active"
}

cmd_storage_install() {
  read -p "Install apa? (contoh: nmap): " pkg

  if [ -z "$pkg" ]; then
    echo "[!] Tidak ada input"
  else
    sudo apt update
    sudo apt install -y "$pkg"

    if [ $? -eq 0 ]; then
      echo "[✔] Install berhasil"
      log_save "Install $pkg"
    else
      echo "[!] Install gagal"
    fi
  fi
}

cmd_storage_save_log() {
  read -p "Ketik YES untuk save log: " confirm

  if [ "$confirm" = "YES" ]; then
    init_storage
    LOG_SRC="$HOME/nettools_logs/nettools_log.txt"

    if [ ! -f "$LOG_SRC" ]; then
      echo "[!] Log file belum ada"
      return
    fi

    cp "$LOG_SRC" "$storage_path/"
    echo "[✔] Log berhasil disimpan"
  else
    echo "[x] Dibatalkan"
  fi
}

# =========================
# COMMAND MAP - USB TOOLS
# =========================

cmd_usb_detect() {
  echo "[~] Available USB devices:"
  lsblk -o NAME,SIZE,MOUNTPOINT | grep "/media\|/run/media"
}

cmd_usb_select() {
  echo "[~] Select USB:"
  lsblk -o NAME,SIZE,MOUNTPOINT | grep "/media\|/run/media"

  read -p "Paste mount path USB: " input

  if [ -d "$input" ]; then
    USB_PATH="$input"
    USB_SELECTED=1
    echo "[✔] USB selected: $USB_PATH"
  else
    echo "[!] Invalid USB path"
    USB_SELECTED=0
  fi
}

cmd_usb_workspace() {
  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] USB belum dipilih"
    return
  fi
  mkdir -p "$USB_PATH/NETTOOLS/logs"
  mkdir -p "$USB_PATH/NETTOOLS/reports"
  echo "[✔] Workspace created"
}

cmd_usb_read() {
  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] USB belum dipilih"
  else
    ls -R "$USB_PATH"
  fi
}

cmd_usb_delete() {
  if [ "$USB_SELECTED" -ne 1 ] || [ -z "$USB_PATH" ]; then
    echo "[!] No USB selected"
  else
    echo "[!] Deleting: $USB_PATH/*"
    read -p "Type YES to confirm: " confirm

    if [ "$confirm" = "YES" ]; then
      if [ -z "$USB_PATH" ] || [ "$USB_PATH" = "/" ]; then
        echo "[!] Unsafe path"
        return
      fi
      if [[ "$USB_PATH" != /media/* && "$USB_PATH" != /run/media/* ]]; then
        echo "[!] Path bukan USB mount valid"
        return
      fi
      if [ ! -d "$USB_PATH" ]; then
        echo "[!] Path USB tidak valid"
        return
      fi
      rm -rf "$USB_PATH"/*
      sync
      echo "[✔] Deleted successfully"

      if [ "$(ls -A "$USB_PATH")" ]; then
        echo "[!] WARNING: Some files still exist"
      else
        echo "[✔] VERIFIED: USB is empty"
      fi
    else
      echo "[x] Cancelled"
    fi
  fi
}

