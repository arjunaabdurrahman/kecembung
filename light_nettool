#!/bin/bash

# =========================
# 🎨 COLORS
# =========================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =========================
# ⚙️ SYSTEM FLAGS
# =========================
set +e
set -o pipefail

CURRENT_PID=0
CURRENT_CHILD=""
RECOVERY_MODE=0
INTERRUPTED=0
RETURN_TO_MAIN=0
CRASH_FLAG=0

WATCHDOG_FILE="/tmp/nettools_watchdog"

# =========================
# 📦 STORAGE CONFIG
# =========================
storage_mode="local"
storage_path="$HOME/nettools_logs"

USB_PATH=""
USB_SELECTED=0

SCENARIO_DIR="$HOME/nettools_scenarios"

mkdir -p "$SCENARIO_DIR"
mkdir -p "$storage_path"

# =========================
# 🔁 PROCESS CONTROL
# =========================

is_alive() {
  [ -n "$1" ] && kill -0 "$1" 2>/dev/null
}

safe_kill() {
  local pid="$1"

  [ -z "$pid" ] && return

  kill "$pid" 2>/dev/null
  sleep 0.5

  kill -TERM "$pid" 2>/dev/null
  sleep 1

  kill -KILL "$pid" 2>/dev/null

  wait "$pid" 2>/dev/null
}

kill_process() {
  local pid="$1"

  [ -z "$pid" ] && return

  if ! kill -0 "$pid" 2>/dev/null; then
    return
  fi

  safe_kill "$pid"
}

cleanup_child() {

  if [ -n "$CURRENT_CHILD" ]; then

    if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
      CURRENT_CHILD=""
    fi

  fi
}

validate_child() {

  if [ -n "$CURRENT_CHILD" ]; then

    if ! kill -0 "$CURRENT_CHILD" 2>/dev/null; then
      CURRENT_CHILD=""
    fi

  fi
}

set_child() {
  local pid="$1"

  sleep 0.1

  if [ -z "$pid" ]; then
    CURRENT_CHILD=""
    return 1
  fi

  if ! kill -0 "$pid" 2>/dev/null; then
    CURRENT_CHILD=""
    return 1
  fi

  CURRENT_CHILD="$pid"
  return 0
}

# =========================
# 🚨 CTRL+C RECOVERY
# =========================

trap_ctrlc() {

  if [ "$RECOVERY_MODE" -eq 1 ]; then
    return
  fi

  echo ""
  echo "[!] CTRL+C DETECTED"

  INTERRUPTED=1
  RECOVERY_MODE=1
  RETURN_TO_MAIN=1

  kill_process "$CURRENT_CHILD"
  kill_process "$CURRENT_PID"

  CURRENT_CHILD=""
  CURRENT_PID=0

  validate_child
}

trap trap_ctrlc SIGINT

reset_state() {

  INTERRUPTED=0
  RETURN_TO_MAIN=0
  RECOVERY_MODE=0
  CRASH_FLAG=0

  if [ -n "$CURRENT_CHILD" ]; then
    kill_process "$CURRENT_CHILD"
  fi

  CURRENT_CHILD=""
  CURRENT_PID=0
}

# =========================
# 🐶 WATCHDOG
# =========================

write_heartbeat() {
  local src="$1"
  echo "$(date +%s)|$src" > "$WATCHDOG_FILE"
}

watchdog_loop() {

  local WATCHDOG_TIMEOUT=120

  while true; do

    sleep 2

    cleanup_child

    [ "$RECOVERY_MODE" -eq 1 ] && continue

    [ ! -f "$WATCHDOG_FILE" ] && continue

    line=$(cat "$WATCHDOG_FILE" 2>/dev/null)

    last=$(echo "$line" | cut -d'|' -f1)

    [[ ! "$last" =~ ^[0-9]+$ ]] && continue

    now=$(date +%s)

    diff=$((now - last))

    if [ "$diff" -ge "$WATCHDOG_TIMEOUT" ]; then

      echo "[!] WATCHDOG FREEZE DETECTED"

      kill_process "$CURRENT_CHILD"
      kill_process "$CURRENT_PID"

      CURRENT_CHILD=""
      CURRENT_PID=0

      RETURN_TO_MAIN=1
      RECOVERY_MODE=1
      INTERRUPTED=1

      write_heartbeat "WATCHDOG_RECOVERY"
    fi

  done
}

# =========================
# 💾 STORAGE SYSTEM
# =========================

init_storage() {

  if [ "$storage_mode" = "local" ]; then

    storage_path="$HOME/nettools_logs"

  else

    if [ -z "$USB_PATH" ]; then

      storage_mode="local"
      storage_path="$HOME/nettools_logs"

    else

      storage_path="$USB_PATH/NETTOOLS"

    fi

  fi

  mkdir -p "$storage_path"
  mkdir -p "$storage_path/captures"
}

log_save() {

  init_storage

  if [ ! -w "$storage_path" ]; then
    echo "[!] Storage not writable"
    return
  fi

  echo "[$(date '+%F %T')] $1" >> "$storage_path/nettools_log.txt"
}

# =========================
# 🔐 PASSWORD CHECK
# =========================

PASS_FILE="$HOME/.nettool_pass"

mkdir -p "$(dirname "$PASS_FILE")"

if [ ! -f "$PASS_FILE" ]; then
  echo "[!] Password belum diset"
  exit 1
fi

echo ""
read -s -p "Masukkan Password NETTOOLS: " input
echo ""

INPUT_HASH=$(echo -n "$input" | sha256sum | awk '{print $1}')

read -r STORED_HASH < "$PASS_FILE"

if [ "$INPUT_HASH" != "$STORED_HASH" ]; then
  echo "[!] Password salah"
  exit 1
fi

echo "[✔] Akses diterima"
sleep 1

touch "$WATCHDOG_FILE"

watchdog_loop &
WATCHDOG_PID=$!

# =========================
# 🌐 IP TOOLS
# =========================

cmd_lihat_ip() {
  ip -brief address
}

cmd_scan_jaringan() {

  if ! command -v nmap >/dev/null 2>&1; then
    echo "[!] nmap belum terinstall"
    return
  fi

  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24

  nmap -sn "$net"
}

cmd_ping_ip() {

  read -p "Target IP: " target

  ping -c 4 "$target"
}

cmd_set_ip_manual() {

  if ! command -v nmcli >/dev/null 2>&1; then
    echo "[!] nmcli tidak tersedia"
    return
  fi

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eno|eth" | head -n 1 | cut -d: -f1)

  read -p "IP (contoh 192.168.1.10/24): " ipbaru
  read -p "Gateway: " gateway

  nmcli con mod "$koneksi" ipv4.addresses "$ipbaru"
  nmcli con mod "$koneksi" ipv4.gateway "$gateway"
  nmcli con mod "$koneksi" ipv4.method manual
  nmcli con up "$koneksi"
}

cmd_routing() {

  ip route

  echo ""
  echo "[~] Gateway:"
  ip route | grep default

  echo ""
  echo "[~] Interface Aktif:"
  ip -brief address | grep UP
}

cmd_dns_check() {

  echo "[~] DNS Aktif:"
  resolvectl status | grep "DNS Servers" -A2
}

cmd_internet_check() {

  ping -c 2 8.8.8.8
}

cmd_scan_ssh() {

  if ! command -v nmap >/dev/null 2>&1; then
    echo "[!] nmap belum terinstall"
    return
  fi

  ipku=$(ip route get 8.8.8.8 | awk '{print $7}')
  net=$(echo "$ipku" | cut -d '.' -f1-3).0/24

  nmap -p 22 --open "$net"
}

cmd_ssh_connect() {

  read -p "Target IP: " target
  read -p "User: " user

  ssh "$user@$target"
}

cmd_reset_ip() {

  if ! command -v nmcli >/dev/null 2>&1; then
    echo "[!] nmcli tidak tersedia"
    return
  fi

  koneksi=$(nmcli -t -f NAME,DEVICE con show --active | grep -E "wlp|eth|eno" | head -n 1 | cut -d: -f1)

  if [ -z "$koneksi" ]; then
    echo "[!] Tidak ada koneksi aktif"
    return
  fi

  sudo nmcli con mod "$koneksi" ipv4.method auto
  sudo nmcli con mod "$koneksi" ipv4.addresses ""
  sudo nmcli con mod "$koneksi" ipv4.gateway ""
  sudo nmcli con mod "$koneksi" ipv4.dns ""

  sudo nmcli con down "$koneksi"
  sudo nmcli con up "$koneksi"

  echo "[✔] IP berhasil di reset"
}

# =========================
# 🔥 TCP TOOLS
# =========================

cmd_tcp_scan_port() {

  read -p "Target: " t

  nmap -sT "$t"
}

cmd_tcp_service_detection() {

  read -p "Target: " t

  nmap -sV "$t"
}

cmd_tcp_range_scan() {

  read -p "Target: " t

  nmap -p 1-1000 "$t"
}

cmd_tcp_specific_port() {

  read -p "Target: " t
  read -p "Port: " p

  nmap -p "$p" "$t"
}

cmd_tcp_local_ports() {

  ss -tuln
}

cmd_tcp_banner_grab() {

  if ! command -v nc >/dev/null 2>&1; then
    echo "[!] netcat tidak tersedia"
    return
  fi

  read -p "Target: " t

  nc -w 3 "$t" 80
}

# =========================
# 💾 STORAGE MODE
# =========================

cmd_storage_local() {

  storage_mode="local"
  storage_path="$HOME/nettools_logs"

  mkdir -p "$storage_path"

  echo "[✔] Local mode active"
}

cmd_storage_usb() {

  if [ "$USB_SELECTED" -ne 1 ]; then
    echo "[!] USB belum dipilih"
    return
  fi

  storage_mode="usb"
  storage_path="$USB_PATH/NETTOOLS"

  mkdir -p "$storage_path"

  echo "[✔] USB mode active"
}

cmd_storage_install() {

  read -p "Install package: " pkg

  [ -z "$pkg" ] && return

  sudo apt update -y
  sudo apt install -y "$pkg"

  if [ $? -eq 0 ]; then

    echo "[✔] Install berhasil"
    log_save "Install $pkg"

  else

    echo "[!] Install gagal"

  fi
}

cmd_storage_save_log() {

  init_storage

  LOG_SRC="$HOME/nettools_logs/nettools_log.txt"

  if [ ! -f "$LOG_SRC" ]; then
    echo "[!] Log belum ada"
    return
  fi

  cp "$LOG_SRC" "$storage_path/"

  echo "[✔] Log berhasil disimpan"
}

# =========================
# 🔌 USB TOOLS
# =========================

cmd_usb_detect() {

  echo "[~] Available USB devices:"

  lsblk -o NAME,SIZE,MOUNTPOINT | grep "/media\|/run/media"
}

cmd_usb_select() {

  echo "[~] Select USB:"
  lsblk -o NAME,SIZE,MOUNTPOINT | grep "/media\|/run/media"

  read -p "Paste mount path USB: " input

  input="${input%/}"

  if [[ "$input" == /media/* || "$input" == /run/media/* ]]; then

    if [ -d "$input" ]; then

      USB_PATH="$input"
      USB_SELECTED=1

      echo "[✔] USB selected: $USB_PATH"

    else

      echo "[!] Path tidak ada"

    fi

  else

    echo "[!] Invalid USB path"
    USB_SELECTED=0

  fi
}

cmd_usb_workspace() {

  if [ "$USB_SELECTED" -ne 1 ]; then
    echo "[!] USB belum dipilih"
    return
  fi

  mkdir -p "$USB_PATH/NETTOOLS/logs"
  mkdir -p "$USB_PATH/NETTOOLS/reports"
  mkdir -p "$USB_PATH/NETTOOLS/captures"

  echo "[✔] Workspace created"
}

cmd_usb_read() {

  if [ "$USB_SELECTED" -ne 1 ]; then
    echo "[!] USB belum dipilih"
    return
  fi

  ls -R "$USB_PATH"
}

cmd_usb_delete() {

  if [ "$USB_SELECTED" -ne 1 ]; then
    echo "[!] USB belum dipilih"
    return
  fi

  echo "[!] WARNING"
  echo "[!] Semua data di USB akan dihapus"

  read -p "Ketik YES untuk lanjut: " confirm

  [ "$confirm" != "YES" ] && return

  if [[ "$USB_PATH" != /media/* && "$USB_PATH" != /run/media/* ]]; then
    echo "[!] BLOCKED"
    return
  fi

  if [ ! -d "$USB_PATH" ]; then
    echo "[!] Invalid path"
    return
  fi

  find "$USB_PATH" -mindepth 1 -maxdepth 5 -exec rm -rf {} \;

  sync

  echo "[✔] USB cleaned safely"
}

# =========================
# 📦 SCENARIO ENGINE
# =========================

run_command() {

  local cmd="$1"

  [ -z "$cmd" ] && return

  case "$cmd" in

    # =====================
    # 🌐 IP TOOLS
    # =====================

    cmd_lihat_ip) cmd_lihat_ip ;;
    cmd_scan_jaringan) cmd_scan_jaringan ;;
    cmd_ping_ip) cmd_ping_ip ;;
    cmd_set_ip_manual) cmd_set_ip_manual ;;
    cmd_routing) cmd_routing ;;
    cmd_dns_check) cmd_dns_check ;;
    cmd_internet_check) cmd_internet_check ;;
    cmd_scan_ssh) cmd_scan_ssh ;;
    cmd_ssh_connect) cmd_ssh_connect ;;
    cmd_reset_ip) cmd_reset_ip ;;

    # =====================
    # 🔥 TCP TOOLS
    # =====================

    cmd_tcp_scan_port) cmd_tcp_scan_port ;;
    cmd_tcp_service_detection) cmd_tcp_service_detection ;;
    cmd_tcp_range_scan) cmd_tcp_range_scan ;;
    cmd_tcp_specific_port) cmd_tcp_specific_port ;;
    cmd_tcp_local_ports) cmd_tcp_local_ports ;;
    cmd_tcp_banner_grab) cmd_tcp_banner_grab ;;

    # =====================
    # 💾 STORAGE
    # =====================

    cmd_storage_local) cmd_storage_local ;;
    cmd_storage_usb) cmd_storage_usb ;;
    cmd_storage_install) cmd_storage_install ;;
    cmd_storage_save_log) cmd_storage_save_log ;;

    # =====================
    # 🔌 USB
    # =====================

    cmd_usb_detect) cmd_usb_detect ;;
    cmd_usb_select) cmd_usb_select ;;
    cmd_usb_workspace) cmd_usb_workspace ;;
    cmd_usb_read) cmd_usb_read ;;
    cmd_usb_delete) cmd_usb_delete ;;

    # =====================
    # ❌ UNKNOWN
    # =====================

    *)
      echo "[!] Unknown command: $cmd"
      ;;

  esac
}

# =========================
# ▶️ RUN SCENARIO FILE
# =========================

run_scenario_file() {

  local file="$1"

  if [ ! -f "$file" ]; then
    echo "[!] Scenario tidak ditemukan"
    return
  fi

  echo "[~] Running scenario: $(basename "$file")"

  local line=0

  while IFS= read -r cmd || [ -n "$cmd" ]; do

    ((line++))

    [ -z "$cmd" ] && continue

    [[ "$cmd" =~ ^# ]] && continue

    cmd=$(echo "$cmd" | xargs)

    [ -z "$cmd" ] && continue

    echo "[SCENARIO:$line] $cmd"

    run_command "$cmd"

    if [ "$RECOVERY_MODE" -eq 1 ]; then
      echo "[!] Recovery aktif"
      break
    fi

  done < "$file"

  echo "[✔] Scenario selesai"
}

# =========================
# ⚙️ BACKGROUND INSTALLER
# =========================

background_install() {

  local packages=(
    "nmap:nmap"
    "figlet:figlet"
    "dialog:dialog"
    "nc:netcat-openbsd"
  )

  (
    sudo apt update -y >/dev/null 2>&1

    for entry in "${packages[@]}"; do

      cmd="${entry%%:*}"
      pkg="${entry##*:}"

      if ! command -v "$cmd" >/dev/null 2>&1; then

        echo "[~] Installing $pkg..."

        sudo apt install -y "$pkg" >/dev/null 2>&1

        if [ $? -eq 0 ]; then
          echo "[✔] $pkg installed"
        else
          echo "[!] Failed install $pkg"
        fi

      fi

    done

  ) &
}

cleanup_child

background_install

# =========================
# 🖥️ MAIN LOOP
# =========================

while true; do

  write_heartbeat "MENU"

  if [ "$RETURN_TO_MAIN" -eq 1 ]; then
    reset_state
    clear
    continue
  fi

  if [ "$RECOVERY_MODE" -eq 1 ]; then
    reset_state
    clear
    continue
  fi

  if [ "$INTERRUPTED" -eq 1 ]; then
    INTERRUPTED=0
    continue
  fi

  clear

  echo -e "${CYAN}=========================${NC}"

  if command -v figlet >/dev/null 2>&1; then
    figlet "LIGHT NETTOOLS"
  else
    echo -e "${GREEN}LIGHT NETTOOLS${NC}"
  fi

  echo -e "${CYAN}=========================${NC}"
  echo -e "${YELLOW}Storage : $storage_mode${NC}"
  echo -e "${BLUE}Path    : $storage_path${NC}"
  echo -e "${CYAN}=========================${NC}"

  echo "1. IP Tools"
  echo "2. TCP Tools"
  echo "3. Storage Mode"
  echo "4. Custom Scenario"
  echo "5. Exit"

  echo -e "${CYAN}=========================${NC}"

  IFS= read -r -p "Pilih menu: " main || continue

  case $main in

    # =====================================================
    # 🌐 IP TOOLS
    # =====================================================

    1)

      while true; do

        write_heartbeat "IP_MENU"

        echo -e "${CYAN}=========================${NC}"
        echo -e "${GREEN}IP TOOLS${NC}"
        echo -e "${CYAN}=========================${NC}"

        echo "1. Lihat IP"
        echo "2. Scan Jaringan"
        echo "3. Ping IP"
        echo "4. Set IP Manual"
        echo "5. Routing"
        echo "6. DNS Check"
        echo "7. Internet Check"
        echo "8. Scan SSH"
        echo "9. SSH Connect"
        echo "10. Reset IP"
        echo "11. Kembali"

        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " ipmenu || continue

        case $ipmenu in

          1) cmd_lihat_ip ;;
          2) cmd_scan_jaringan ;;
          3) cmd_ping_ip ;;
          4) cmd_set_ip_manual ;;
          5) cmd_routing ;;
          6) cmd_dns_check ;;
          7) cmd_internet_check ;;
          8) cmd_scan_ssh ;;
          9) cmd_ssh_connect ;;
          10) cmd_reset_ip ;;
          11) break ;;

        esac

      done
      ;;

    # =====================================================
    # 🔥 TCP TOOLS
    # =====================================================

    2)

      while true; do

        write_heartbeat "TCP_MENU"

        echo -e "${CYAN}=========================${NC}"
        echo -e "${GREEN}TCP TOOLS${NC}"
        echo -e "${CYAN}=========================${NC}"

        echo "1. Scan Port"
        echo "2. Service Detection"
        echo "3. Range Scan"
        echo "4. Specific Port"
        echo "5. Local Ports"
        echo "6. Banner Grab"
        echo "7. Kembali"

        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " tcpmenu || continue

        case $tcpmenu in

          1) cmd_tcp_scan_port ;;
          2) cmd_tcp_service_detection ;;
          3) cmd_tcp_range_scan ;;
          4) cmd_tcp_specific_port ;;
          5) cmd_tcp_local_ports ;;
          6) cmd_tcp_banner_grab ;;
          7) break ;;

        esac

      done
      ;;

    # =====================================================
    # 💾 STORAGE MODE
    # =====================================================

    3)

      while true; do

        write_heartbeat "STORAGE_MENU"

        echo -e "${CYAN}=========================${NC}"
        echo -e "${YELLOW}STORAGE MODE${NC}"
        echo -e "${CYAN}=========================${NC}"

        echo "1. Local Mode"
        echo "2. USB Mode"
        echo "3. Install Package"
        echo "4. Save Log"
        echo "5. USB Tools"
        echo "6. Kembali"

        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " smenu || continue

        case $smenu in

          1) cmd_storage_local ;;
          2) cmd_storage_usb ;;
          3) cmd_storage_install ;;
          4) cmd_storage_save_log ;;

          5)

            while true; do

              write_heartbeat "USB_MENU"

              echo -e "${CYAN}=========================${NC}"
              echo -e "${GREEN}USB TOOLS${NC}"
              echo -e "${CYAN}=========================${NC}"

              echo "1. Detect USB"
              echo "2. Select USB"
              echo "3. Create Workspace"
              echo "4. Read Data"
              echo "5. Delete Data"
              echo "6. Kembali"

              echo -e "${CYAN}=========================${NC}"

              IFS= read -r -p "Pilih menu: " usbmenu || continue

              case $usbmenu in

                1) cmd_usb_detect ;;
                2) cmd_usb_select ;;
                3) cmd_usb_workspace ;;
                4) cmd_usb_read ;;
                5) cmd_usb_delete ;;
                6) break ;;

              esac

            done
            ;;

          6) break ;;

        esac

      done
      ;;

    # =====================================================
    # 📦 CUSTOM SCENARIO
    # =====================================================

    4)

      while true; do

        write_heartbeat "SCENARIO_MENU"

        echo -e "${CYAN}=========================${NC}"
        echo -e "${CYAN}CUSTOM SCENARIO${NC}"
        echo -e "${CYAN}=========================${NC}"

        echo "1. Jalankan Scenario"
        echo "2. Buat Scenario"
        echo "3. Kembali"

        echo -e "${CYAN}=========================${NC}"

        IFS= read -r -p "Pilih menu: " sub || continue

        case $sub in

          1)

            shopt -s nullglob
            files=("$SCENARIO_DIR"/*.sh)
            shopt -u nullglob

            if [ ${#files[@]} -eq 0 ]; then
              echo "[!] Tidak ada scenario"
              continue
            fi

            echo -e "${CYAN}=========================${NC}"

            for i in "${!files[@]}"; do
              echo "$i. $(basename "${files[$i]}")"
            done

            echo -e "${CYAN}=========================${NC}"

            read -p "Pilih scenario: " pilih

            if [ -n "${files[$pilih]}" ]; then

              run_scenario_file "${files[$pilih]}"

              log_save "Run scenario $(basename "${files[$pilih]}")"

            else

              echo "[!] Pilihan tidak valid"

            fi
            ;;

          2)

            if [ -f ~/scenario_builder.sh ]; then
              bash ~/scenario_builder.sh
            else
              echo "[!] scenario_builder.sh tidak ditemukan"
            fi
            ;;

          3)
            break
            ;;

        esac

      done
      ;;

    # =====================================================
    # 🚪 EXIT
    # =====================================================

    5)

      echo -e "${RED}Exiting NETTOOLS...${NC}"

      pkill -P $$ 2>/dev/null

      kill "$WATCHDOG_PID" 2>/dev/null

      sleep 1

      clear

      break
      ;;

    *)

      echo "[!] Invalid option"
      ;;

  esac

done
